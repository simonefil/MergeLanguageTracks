<div class="dialog-overlay visible" @onclick="OnClose">
    <div class="dialog-box" style="min-width: 60ch; max-height: 80vh; overflow-y: auto;" @onclick:stopPropagation="true">
        <div class="dialog-title">@AppText.T("web.advanced.title")</div>
        <div class="dialog-body">

            @* Sezione opzioni utente *@
            <AdvancedSettingsSection Title="Analysis">
                <AdvancedSettingsToggleRow Label="Hardware Acceleration" @bind-Value="_ffHardwareAcceleration" />
                <AdvancedSettingsFieldRow Label="FrameWidth:" Width="10ch" @bind-Value="_vsFrameWidth" />
                <AdvancedSettingsFieldRow Label="FrameHeight:" Width="10ch" @bind-Value="_vsFrameHeight" />
                <AdvancedSettingsFieldRow Label="NumCheckPoints:" Width="10ch" @bind-Value="_vsNumCheckPoints" />
                <AdvancedSettingsFieldRow Label="MinValidPoints:" Width="10ch" @bind-Value="_vsMinValidPoints" />
            </AdvancedSettingsSection>

            <AdvancedSettingsSection Title="Frame Sync">
                <AdvancedSettingsFieldRow Label="SourceDurationSec:" Width="10ch" @bind-Value="_fsSourceDurationSec" />
                <AdvancedSettingsFieldRow Label="LangDurationSec:" Width="10ch" @bind-Value="_fsLangDurationSec" />
                <AdvancedSettingsFieldRow Label="MinValidPoints:" Width="10ch" @bind-Value="_fsMinValidPoints" />
                <AdvancedSettingsToggleRow Label="AudioGlobalEnabled" @bind-Value="_fsAudioGlobalEnabled" />
            </AdvancedSettingsSection>

            <AdvancedSettingsSection Title="Deep Analysis">
                <AdvancedSettingsFieldRow Label="GlobalVerifyPoints:" Width="10ch" @bind-Value="_daGlobalVerifyPoints" />
                <AdvancedSettingsFieldRow Label="GlobalVerifyMinRatio:" Width="10ch" @bind-Value="_daGlobalVerifyMinRatio" />
                <AdvancedSettingsFieldRow Label="SceneExtractTimeoutMs:" Width="10ch" @bind-Value="_daSceneExtractTimeoutMs" />
            </AdvancedSettingsSection>

            <AdvancedSettingsSection Title="Timeouts">
                <AdvancedSettingsFieldRow Label="SubtitleEditFfmpegTimeoutMs:" Width="10ch" @bind-Value="_subtitleEditFfmpegTimeoutMs" />
            </AdvancedSettingsSection>

        </div>
        @if (_validationError.Length > 0)
        {
            <div style="padding: 0.5em 1em; color: var(--color-error); white-space: pre-line;">@_validationError</div>
        }
        <div class="dialog-footer">
            <button @onclick="Save">@AppText.T("web.common.ok")</button>
            <button @onclick="ResetDefaults">@AppText.T("web.advanced.resetDefault")</button>
            <button @onclick="OnClose">@AppText.T("web.common.cancel")</button>
        </div>
    </div>
</div>

@code {
    /// <summary>
    /// Evento chiusura dialog
    /// </summary>
    [Parameter] public EventCallback OnClose { get; set; }

    #region Campi VideoSync

    private string _vsFrameWidth = "";
    private string _vsFrameHeight = "";
    private string _vsNumCheckPoints = "";
    private string _vsMinValidPoints = "";

    #endregion

    #region Campi FrameSync

    private string _fsSourceDurationSec = "";
    private string _fsLangDurationSec = "";
    private string _fsMinValidPoints = "";
    private bool _fsAudioGlobalEnabled;

    #endregion

    #region Campi DeepAnalysis

    private string _daSceneExtractTimeoutMs = "";
    private string _daGlobalVerifyPoints = "";
    private string _daGlobalVerifyMinRatio = "";

    #endregion

    #region Campi SubtitleEdit

    /// <summary>
    /// Timeout comando ffmpeg (ms)
    /// </summary>
    private string _subtitleEditFfmpegTimeoutMs = "";

    #endregion

    #region Ffmpeg

    /// <summary>
    /// Accelerazione hardware ffmpeg
    /// </summary>
    private bool _ffHardwareAcceleration;

    #endregion

    /// <summary>
    /// Messaggio errore validazione
    /// </summary>
    private string _validationError = "";

    /// <summary>
    /// Carica valori correnti da AppSettings
    /// </summary>
    protected override void OnInitialized()
    {
        LoadFields();
    }

    /// <summary>
    /// Carica tutti i campi dal model corrente
    /// </summary>
    private void LoadFields()
    {
        AdvancedConfig adv = AppSettingsService.Instance.Settings.Advanced;
        LoadFieldsFrom(adv);
    }

    /// <summary>
    /// Carica tutti i campi dal model indicato
    /// </summary>
    private void LoadFieldsFrom(AdvancedConfig adv)
    {
        // VideoSync — interi
        _vsFrameWidth = adv.VideoSync.FrameWidth.ToString();
        _vsFrameHeight = adv.VideoSync.FrameHeight.ToString();
        _vsNumCheckPoints = adv.VideoSync.NumCheckPoints.ToString();
        _vsMinValidPoints = adv.VideoSync.MinValidPoints.ToString();

        // FrameSync — interi
        _fsSourceDurationSec = adv.FrameSync.SourceDurationSec.ToString();
        _fsLangDurationSec = adv.FrameSync.LangDurationSec.ToString();
        _fsMinValidPoints = adv.FrameSync.MinValidPoints.ToString();

        // FrameSync — booleani
        _fsAudioGlobalEnabled = adv.FrameSync.AudioGlobalEnabled;

        _daGlobalVerifyMinRatio = adv.DeepAnalysis.GlobalVerifyMinRatio.ToString(System.Globalization.CultureInfo.InvariantCulture);

        // DeepAnalysis — interi
        _daSceneExtractTimeoutMs = adv.DeepAnalysis.SceneExtractTimeoutMs.ToString();
        _daGlobalVerifyPoints = adv.DeepAnalysis.GlobalVerifyPoints.ToString();

        // SubtitleEdit — interi
        _subtitleEditFfmpegTimeoutMs = adv.SubtitleEdit.FfmpegTimeoutMs.ToString();

        // Ffmpeg — booleani
        _ffHardwareAcceleration = adv.Ffmpeg.HardwareAcceleration;
    }

    /// <summary>
    /// Salva impostazioni avanzate con validazione, non chiude se errore
    /// </summary>
    private void Save()
    {
        _validationError = "";
        AdvancedConfig adv = AppSettingsService.Instance.Settings.Advanced;
        int intVal;
        double dblVal;

        if (!ValidateAdvancedFields())
        {
            return;
        }

        // Parsing VideoSync — interi
        if (int.TryParse(_vsFrameWidth, out intVal)) { adv.VideoSync.FrameWidth = intVal; }
        if (int.TryParse(_vsFrameHeight, out intVal)) { adv.VideoSync.FrameHeight = intVal; }
        if (int.TryParse(_vsNumCheckPoints, out intVal)) { adv.VideoSync.NumCheckPoints = intVal; }
        if (int.TryParse(_vsMinValidPoints, out intVal)) { adv.VideoSync.MinValidPoints = intVal; }

        // Parsing FrameSync — interi
        if (int.TryParse(_fsSourceDurationSec, out intVal)) { adv.FrameSync.SourceDurationSec = intVal; }
        if (int.TryParse(_fsLangDurationSec, out intVal)) { adv.FrameSync.LangDurationSec = intVal; }
        if (int.TryParse(_fsMinValidPoints, out intVal)) { adv.FrameSync.MinValidPoints = intVal; }

        // Parsing FrameSync — booleani
        adv.FrameSync.AudioGlobalEnabled = _fsAudioGlobalEnabled;

        // Parsing DeepAnalysis — double
        if (double.TryParse(_daGlobalVerifyMinRatio, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out dblVal)) { adv.DeepAnalysis.GlobalVerifyMinRatio = dblVal; }

        // Parsing DeepAnalysis — interi
        if (int.TryParse(_daSceneExtractTimeoutMs, out intVal)) { adv.DeepAnalysis.SceneExtractTimeoutMs = intVal; }
        if (int.TryParse(_daGlobalVerifyPoints, out intVal)) { adv.DeepAnalysis.GlobalVerifyPoints = intVal; }

        // Parsing SubtitleEdit — interi
        if (int.TryParse(_subtitleEditFfmpegTimeoutMs, out intVal)) { adv.SubtitleEdit.FfmpegTimeoutMs = intVal; }

        // Parsing Ffmpeg — booleani
        adv.Ffmpeg.HardwareAcceleration = _ffHardwareAcceleration;

        _validationError = "";
        AppSettingsService.Instance.Save();
        OnClose.InvokeAsync();
    }

    /// <summary>
    /// Ripristina valori di default per tutte le sezioni avanzate
    /// </summary>
    private void ResetDefaults()
    {
        // Ricarica default nei campi; il salvataggio avviene solo con OK
        _validationError = "";
        LoadFieldsFrom(new AdvancedConfig());
    }

    /// <summary>
    /// Valida tutti i campi avanzati con gli stessi range del Core
    /// </summary>
    private bool ValidateAdvancedFields()
    {
        List<string> errors = new List<string>();

        AdvancedSettingsFieldValidator.ValidateIntRange(errors, "VideoSync.FrameWidth", _vsFrameWidth, 64, 1920);
        AdvancedSettingsFieldValidator.ValidateIntRange(errors, "VideoSync.FrameHeight", _vsFrameHeight, 64, 1080);
        AdvancedSettingsFieldValidator.ValidateIntRange(errors, "VideoSync.NumCheckPoints", _vsNumCheckPoints, 1, 1000);
        AdvancedSettingsFieldValidator.ValidateIntRange(errors, "VideoSync.MinValidPoints", _vsMinValidPoints, 1, 1000);

        AdvancedSettingsFieldValidator.ValidateIntRange(errors, "FrameSync.SourceDurationSec", _fsSourceDurationSec, 1, 3600);
        AdvancedSettingsFieldValidator.ValidateIntRange(errors, "FrameSync.LangDurationSec", _fsLangDurationSec, 1, 3600);
        AdvancedSettingsFieldValidator.ValidateIntRange(errors, "FrameSync.MinValidPoints", _fsMinValidPoints, 1, 1000);

        AdvancedSettingsFieldValidator.ValidateIntRange(errors, "DeepAnalysis.SceneExtractTimeoutMs", _daSceneExtractTimeoutMs, 1000, 3600000);
        AdvancedSettingsFieldValidator.ValidateIntRange(errors, "DeepAnalysis.GlobalVerifyPoints", _daGlobalVerifyPoints, 1, 1000);
        AdvancedSettingsFieldValidator.ValidateDoubleRange(errors, "DeepAnalysis.GlobalVerifyMinRatio", _daGlobalVerifyMinRatio, 0.0, 1.0);

        AdvancedSettingsFieldValidator.ValidateIntRange(errors, "SubtitleEdit.FfmpegTimeoutMs", _subtitleEditFfmpegTimeoutMs, 1000, 3600000);

        if (errors.Count > 0)
        {
            _validationError = string.Join("\n", errors);
            return false;
        }

        return true;
    }
}
