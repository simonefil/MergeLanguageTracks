<div class="dialog-overlay visible" @onclick="OnClose">
    <div class="dialog-box" style="min-width: 80ch; max-width: 100ch; max-height: 80vh;" @onclick:stopPropagation="true">
        <div class="dialog-title">@AppText.F("web.mediaInfo.title", Title)</div>
        <div class="dialog-body" style="max-height: 60vh; overflow-y: auto;">
            <pre style="white-space: pre-wrap; font-size: 0.9em; color: var(--foreground0);">@(Report.Length > 0 ? Report : AppText.T("web.mediaInfo.noReport"))</pre>
        </div>
        <div class="dialog-footer">
            <button @onclick="CopyReport">@AppText.T("web.common.copy")</button>
            <button @onclick="OnClose">@AppText.T("web.common.close")</button>
        </div>
    </div>
</div>

@code {
    /// <summary>
    /// Titolo del dialog
    /// </summary>
    [Parameter] public string Title { get; set; }

    /// <summary>
    /// Report mediainfo testuale
    /// </summary>
    [Parameter] public string Report { get; set; }

    /// <summary>
    /// Modulo JS interop per clipboard
    /// </summary>
    [Parameter] public IJSObjectReference JsModule { get; set; }

    /// <summary>
    /// Evento chiusura dialog
    /// </summary>
    [Parameter] public EventCallback OnClose { get; set; }

    /// <summary>
    /// Copia il report nella clipboard via JS interop
    /// </summary>
    private void CopyReport()
    {
        if (JsModule != null && Report.Length > 0)
        {
            try
            {
                _ = JsModule.InvokeVoidAsync("copyToClipboard", Report);
            }
            catch
            {
                // Ignora errori clipboard
            }
        }
    }
}
