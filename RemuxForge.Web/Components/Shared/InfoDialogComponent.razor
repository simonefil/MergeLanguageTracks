<div class="dialog-overlay visible" @onclick="OnClose">
    <div class="dialog-box" style="min-width: 55ch;" @onclick:stopPropagation="true">
        <div class="dialog-title">@AppText.T("web.info.title")</div>
        <div class="dialog-body">
            <table class="info-table">
                <tr><td class="info-label">@AppText.T("web.info.name")</td><td><img src="favicon-32x32.png" alt="icon" style="vertical-align: middle; margin-right: 0.5ch;" />RemuxForge</td></tr>
                <tr><td class="info-label">@AppText.T("web.info.version")</td><td>@_version</td></tr>
                <tr><td class="info-label">@AppText.T("web.info.license")</td><td>GNU General Public License v3.0</td></tr>
                <tr><td class="info-label">@AppText.T("web.info.repository")</td><td><a href="https://github.com/simonefil/RemuxForge" target="_blank">https://github.com/simonefil/RemuxForge</a></td></tr>
                <tr><td class="info-label">@AppText.T("web.info.runtime")</td><td>@_runtime</td></tr>
                <tr><td class="info-label">@AppText.T("web.info.platform")</td><td>@_platform</td></tr>
            </table>
        </div>
        <div class="dialog-footer">
            <button @onclick="OnClose">@AppText.T("web.common.close")</button>
        </div>
    </div>
</div>

<style>
    .info-table {
        border-collapse: collapse;
        width: 100%;
    }
    .info-table:before {
        display: none !important;
    }
    .info-table tr td:before,
    .info-table tr td:after {
        display: none !important;
    }
    .info-table :first-child > tr:first-child > td {
        padding-top: 0 !important;
    }
    .info-table tr td {
        padding: 0 1ch;
        line-height: 1lh;
        padding-bottom: 0 !important;
    }
    .info-label {
        font-weight: bold;
        width: 14ch;
    }
    .info-table a {
        color: var(--accent);
    }
</style>

@code {
    /// <summary>
    /// Evento chiusura dialog
    /// </summary>
    [Parameter] public EventCallback OnClose { get; set; }

    /// <summary>
    /// Versione applicazione
    /// </summary>
    private string _version;

    /// <summary>
    /// Descrizione runtime
    /// </summary>
    private string _runtime;

    /// <summary>
    /// Descrizione piattaforma
    /// </summary>
    private string _platform;

    /// <summary>
    /// Inizializza informazioni di sistema
    /// </summary>
    protected override void OnInitialized()
    {
        // Versione dall'assembly
        System.Reflection.Assembly assembly = System.Reflection.Assembly.GetEntryAssembly();
        System.Reflection.CustomAttributeData infoAttr = null;
        Version assemblyVersion;

        if (assembly != null)
        {
            foreach (System.Reflection.CustomAttributeData attr in assembly.CustomAttributes)
            {
                if (attr.AttributeType == typeof(System.Reflection.AssemblyInformationalVersionAttribute))
                {
                    infoAttr = attr;
                    break;
                }
            }
        }

        if (infoAttr != null && infoAttr.ConstructorArguments.Count > 0 && infoAttr.ConstructorArguments[0].Value != null)
        {
            this._version = infoAttr.ConstructorArguments[0].Value.ToString();
        }
        else if (assembly != null)
        {
            assemblyVersion = assembly.GetName().Version;
            this._version = assemblyVersion != null ? assemblyVersion.ToString() : "";
        }
        else
        {
            this._version = "";
        }

        // Runtime e piattaforma
        this._runtime = System.Runtime.InteropServices.RuntimeInformation.FrameworkDescription;
        this._platform = System.Runtime.InteropServices.RuntimeInformation.OSDescription;
    }
}
