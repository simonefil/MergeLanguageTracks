<div class="dialog-overlay visible" @onclick="OnClose">
    <div class="dialog-box" style="min-width: 60ch;" @onclick:stopPropagation="true">
        <div class="dialog-title">Percorsi Tool</div>
        <div class="dialog-body">
            <div class="form-row">
                <span class="form-label">mkvmerge:</span>
                <input class="form-input" @bind="_mkvPath" />
                <span class="btn-browse" @onclick="() => BrowseFolder(0)">[ .. ]</span>
                <span style="margin-left: 0.5ch; color: var(@(_mkvFound ? "--color-ok" : "--color-error"));">@(_mkvFound ? "[OK]" : "[NON TROVATO]")</span>
            </div>
            <div class="form-row">
                <span class="form-label">mkvextract:</span>
                <input class="form-input" @bind="_mkvExtractPath" />
                <span class="btn-browse" @onclick="() => BrowseFolder(4)">[ .. ]</span>
                <span style="margin-left: 0.5ch; color: var(@(_mkvExtractFound ? "--color-ok" : "--color-error"));">@(_mkvExtractFound ? "[OK]" : "[NON TROVATO]")</span>
            </div>
            <div class="form-row">
                <span class="form-label">mkvpropedit:</span>
                <input class="form-input" @bind="_mkvPropEditPath" />
                <span class="btn-browse" @onclick="() => BrowseFolder(5)">[ .. ]</span>
                <span style="margin-left: 0.5ch; color: var(@(_mkvPropEditFound ? "--color-ok" : "--color-error"));">@(_mkvPropEditFound ? "[OK]" : "[NON TROVATO]")</span>
            </div>
            <div class="form-row">
                <span class="form-label">ffmpeg:</span>
                <input class="form-input" @bind="_ffmpegPath" />
                <span class="btn-browse" @onclick="() => BrowseFolder(1)">[ .. ]</span>
                <span style="margin-left: 0.5ch; color: var(@(_ffmpegFound ? "--color-ok" : "--color-error"));">@(_ffmpegStatusText)</span>
                @if (!_ffmpegFound && !_ffmpegDownloading)
                {
                    <span class="btn-browse" style="margin-left: 0.5ch;" @onclick="DownloadFfmpeg">[ Scarica ]</span>
                }
            </div>
            <div class="form-row">
                <span class="form-label">ffprobe:</span>
                <input class="form-input" @bind="_ffprobePath" />
                <span class="btn-browse" @onclick="() => BrowseFolder(6)">[ .. ]</span>
                <span style="margin-left: 0.5ch; color: var(@(_ffprobeFound ? "--color-ok" : "--color-error"));">@(_ffprobeFound ? "[OK]" : "[NON TROVATO]")</span>
            </div>
            <div class="form-row">
                <span class="form-label">mediainfo:</span>
                <input class="form-input" @bind="_mediaInfoPath" />
                <span class="btn-browse" @onclick="() => BrowseFolder(2)">[ .. ]</span>
                <span style="margin-left: 0.5ch; color: var(@(_mediaInfoFound ? "--color-ok" : "--color-error"));">@(_mediaInfoFound ? "[OK]" : "[CLI NON TROVATA]")</span>
            </div>
            <div class="form-row" style="margin-top: 0.5em;">
                <span class="form-label">temp:</span>
                <input class="form-input" @bind="_tempFolder" />
                <span class="btn-browse" @onclick="() => BrowseFolder(3)">[ .. ]</span>
            </div>
        </div>
        @if (_validationError.Length > 0)
        {
            <div style="padding: 0.5em 1em; color: var(--color-error); white-space: pre-line;">@_validationError</div>
        }
        <div class="dialog-footer">
            <button @onclick="Save">OK</button>
            <button @onclick="OnClose">Annulla</button>
        </div>
    </div>
</div>

@* Dialog browse file *@
@if (_showBrowse)
{
    <FolderBrowserDialog InitialPath="@_browseInitialPath"
                          ShowFiles="true"
                          OnClose="CloseBrowse"
                          OnSelect="ApplyBrowse" />
}

@code {
    /// <summary>
    /// Evento chiusura dialog
    /// </summary>
    [Parameter] public EventCallback OnClose { get; set; }

    /// <summary>
    /// Percorso mkvmerge
    /// </summary>
    private string _mkvPath = "";

    /// <summary>
    /// Percorso mkvextract
    /// </summary>
    private string _mkvExtractPath = "";

    /// <summary>
    /// Percorso mkvpropedit
    /// </summary>
    private string _mkvPropEditPath = "";

    /// <summary>
    /// Percorso ffmpeg
    /// </summary>
    private string _ffmpegPath = "";

    /// <summary>
    /// Percorso ffprobe
    /// </summary>
    private string _ffprobePath = "";

    /// <summary>
    /// Percorso mediainfo
    /// </summary>
    private string _mediaInfoPath = "";

    /// <summary>
    /// Flag: mkvmerge trovato
    /// </summary>
    private bool _mkvFound;

    /// <summary>
    /// Flag: mkvextract trovato
    /// </summary>
    private bool _mkvExtractFound;

    /// <summary>
    /// Flag: mkvpropedit trovato
    /// </summary>
    private bool _mkvPropEditFound;

    /// <summary>
    /// Flag: ffmpeg trovato
    /// </summary>
    private bool _ffmpegFound;

    /// <summary>
    /// Flag: ffprobe trovato
    /// </summary>
    private bool _ffprobeFound;

    /// <summary>
    /// Flag: download ffmpeg in corso
    /// </summary>
    private bool _ffmpegDownloading;

    /// <summary>
    /// Testo stato ffmpeg
    /// </summary>
    private string _ffmpegStatusText = "[NON TROVATO]";

    /// <summary>
    /// Flag: mediainfo trovato
    /// </summary>
    private bool _mediaInfoFound;

    /// <summary>
    /// Percorso cartella file temporanei
    /// </summary>
    private string _tempFolder = "";

    /// <summary>
    /// Risolutore centralizzato per i tool path
    /// </summary>
    private ToolPathResolverService _toolPathResolver;

    /// <summary>
    /// Flag: mostra dialog browse
    /// </summary>
    private bool _showBrowse;

    /// <summary>
    /// Percorso iniziale per il dialog browse
    /// </summary>
    private string _browseInitialPath = "";

    /// <summary>
    /// Indice campo destinazione del browse: 0=mkv, 1=ffmpeg, 2=mediainfo
    /// </summary>
    private int _browseFieldIndex = -1;

    /// <summary>
    /// Messaggio errore validazione
    /// </summary>
    private string _validationError = "";

    /// <summary>
    /// Carica valori correnti da AppSettings (auto-find gia' fatto all'avvio)
    /// </summary>
    protected override void OnInitialized()
    {
        this._toolPathResolver = new ToolPathResolverService(AppSettingsService.Instance.ConfigFolder);

        // mkvmerge
        _mkvPath = this._toolPathResolver.ResolveMkvMergePath(false);
        if (_mkvPath.Length == 0)
        {
            _mkvPath = AppSettingsService.Instance.Settings.Tools.MkvMergePath;
        }

        _mkvFound = _mkvPath.Length > 0 && _mkvPath != "mkvmerge" && System.IO.File.Exists(_mkvPath);

        // mkvextract / mkvpropedit
        _mkvExtractPath = this._toolPathResolver.ResolveMkvExtractPath(_mkvPath, false);
        if (_mkvExtractPath.Length == 0) { _mkvExtractPath = AppSettingsService.Instance.Settings.Tools.MkvExtractPath; }
        _mkvExtractFound = _mkvExtractPath.Length > 0 && System.IO.File.Exists(_mkvExtractPath);

        _mkvPropEditPath = this._toolPathResolver.ResolveMkvPropEditPath(_mkvPath, false);
        if (_mkvPropEditPath.Length == 0) { _mkvPropEditPath = AppSettingsService.Instance.Settings.Tools.MkvPropEditPath; }
        _mkvPropEditFound = _mkvPropEditPath.Length > 0 && System.IO.File.Exists(_mkvPropEditPath);

        // ffmpeg
        _ffmpegPath = this._toolPathResolver.ResolveFfmpegPath(false, false);
        if (_ffmpegPath.Length == 0)
        {
            _ffmpegPath = AppSettingsService.Instance.Settings.Tools.FfmpegPath;
        }

        _ffmpegFound = _ffmpegPath.Length > 0 && System.IO.File.Exists(_ffmpegPath);
        _ffmpegStatusText = _ffmpegFound ? "[OK]" : "[NON TROVATO]";

        // ffprobe
        _ffprobePath = this._toolPathResolver.ResolveFfprobePath(_ffmpegPath, false);
        if (_ffprobePath.Length == 0) { _ffprobePath = AppSettingsService.Instance.Settings.Tools.FfprobePath; }
        _ffprobeFound = _ffprobePath.Length > 0 && System.IO.File.Exists(_ffprobePath);

        // mediainfo
        _mediaInfoPath = this._toolPathResolver.ResolveMediaInfoPath(false);
        if (_mediaInfoPath.Length == 0)
        {
            _mediaInfoPath = AppSettingsService.Instance.Settings.Tools.MediaInfoPath;
        }

        _mediaInfoFound = _mediaInfoPath.Length > 0 && System.IO.File.Exists(_mediaInfoPath) && this._toolPathResolver.IsMediaInfoCliPath(_mediaInfoPath);

        // cartella temp
        _tempFolder = AppSettingsService.Instance.Settings.Tools.TempFolder;
    }

    /// <summary>
    /// Salva percorsi con validazione, non chiude se errore
    /// </summary>
    private void Save()
    {
        // Aggiorna model
        AppSettingsService.Instance.Settings.Tools.MkvMergePath = _mkvPath;
        AppSettingsService.Instance.Settings.Tools.MkvExtractPath = _mkvExtractPath;
        AppSettingsService.Instance.Settings.Tools.MkvPropEditPath = _mkvPropEditPath;
        AppSettingsService.Instance.Settings.Tools.FfmpegPath = _ffmpegPath;
        AppSettingsService.Instance.Settings.Tools.FfprobePath = _ffprobePath;
        AppSettingsService.Instance.Settings.Tools.MediaInfoPath = _mediaInfoPath;
        AppSettingsService.Instance.Settings.Tools.TempFolder = _tempFolder;

        // Valida percorsi
        string errorMessage;
        if (!AppSettingsService.Instance.ValidateToolPaths(out errorMessage))
        {
            _validationError = errorMessage;
            return;
        }

        _validationError = "";
        AppSettingsService.Instance.Save();
        OnClose.InvokeAsync();
    }

    /// <summary>
    /// Apre il dialog browse cartella per il campo specificato
    /// </summary>
    /// <param name="fieldIndex">Indice campo: 0=mkv, 1=ffmpeg, 2=mediainfo, 3=temp</param>
    private void BrowseFolder(int fieldIndex)
    {
        _browseFieldIndex = fieldIndex;

        if (fieldIndex == 0) { _browseInitialPath = _mkvPath; }
        else if (fieldIndex == 1) { _browseInitialPath = _ffmpegPath; }
        else if (fieldIndex == 2) { _browseInitialPath = _mediaInfoPath; }
        else if (fieldIndex == 3) { _browseInitialPath = _tempFolder; }
        else if (fieldIndex == 4) { _browseInitialPath = _mkvExtractPath; }
        else if (fieldIndex == 5) { _browseInitialPath = _mkvPropEditPath; }
        else if (fieldIndex == 6) { _browseInitialPath = _ffprobePath; }

        _showBrowse = true;
    }

    /// <summary>
    /// Chiude il dialog browse
    /// </summary>
    private void CloseBrowse()
    {
        _showBrowse = false;
    }

    /// <summary>
    /// Applica il percorso selezionato dal dialog browse
    /// </summary>
    /// <param name="selectedPath">Percorso selezionato</param>
    private void ApplyBrowse(string selectedPath)
    {
        _showBrowse = false;

        if (string.IsNullOrEmpty(selectedPath)) { return; }

        if (_browseFieldIndex == 0) { _mkvPath = selectedPath; }
        else if (_browseFieldIndex == 1) { _ffmpegPath = selectedPath; }
        else if (_browseFieldIndex == 2) { _mediaInfoPath = selectedPath; }
        else if (_browseFieldIndex == 3) { _tempFolder = selectedPath; }
        else if (_browseFieldIndex == 4) { _mkvExtractPath = selectedPath; }
        else if (_browseFieldIndex == 5) { _mkvPropEditPath = selectedPath; }
        else if (_browseFieldIndex == 6) { _ffprobePath = selectedPath; }
    }

    /// <summary>
    /// Scarica ffmpeg su thread background e aggiorna lo stato
    /// </summary>
    private void DownloadFfmpeg()
    {
        _ffmpegDownloading = true;
        _ffmpegStatusText = "[Download...]";

        Thread dlThread = new Thread(() =>
        {
            bool dlResult = this._toolPathResolver.ResolveFfmpegPath(true, true).Length > 0;

            InvokeAsync(() =>
            {
                _ffmpegDownloading = false;
                if (dlResult)
                {
                    _ffmpegPath = this._toolPathResolver.ResolveFfmpegPath(false, false);
                    _ffmpegFound = true;
                    _ffmpegStatusText = "[OK]";
                }
                else
                {
                    _ffmpegStatusText = "[ERRORE]";
                }
                StateHasChanged();
            });
        });
        dlThread.IsBackground = true;
        dlThread.Start();
    }
}
