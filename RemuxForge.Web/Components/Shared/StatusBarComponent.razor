<div class="status-bar">
    <span class="cmd-key" @onclick="OnShowConfig"><span class="key-label">F2</span>@AppText.T("web.status.config")</span>
    <span class="cmd-key" @onclick="OnScan"><span class="key-label">F5</span>@AppText.T("web.status.scan")</span>
    @if (CurrentMode == Options.MODE_SPLIT)
    {
        <span class="cmd-key" @onclick="OnMergeAll"><span class="key-label">F10</span>@AppText.T("web.status.splitAll")</span>
    }
    else
    {
        <span class="cmd-key" @onclick="OnAnalyzeSelected"><span class="key-label">F6</span>@AppText.T("web.status.analyze")</span>
        <span class="cmd-key" @onclick="OnAnalyzeAll"><span class="key-label">F7</span>@AppText.T("web.status.all")</span>
        <span class="cmd-key" @onclick="OnSkip"><span class="key-label">F8</span>@AppText.T("web.status.skip")</span>
        <span class="cmd-key" @onclick="OnMergeSelected"><span class="key-label">F9</span>@AppText.T("web.status.process")</span>
        <span class="cmd-key" @onclick="OnMergeAll"><span class="key-label">F10</span>@AppText.T("web.status.all")</span>
    }
    <span class="cmd-key" @onclick="OnStop"><span class="key-label">F12</span>@AppText.T("web.status.stop")</span>
</div>

@code {
    /// <summary>
    /// Evento scan file
    /// </summary>
    [Parameter] public EventCallback OnScan { get; set; }

    /// <summary>
    /// Evento analizza selezionato
    /// </summary>
    [Parameter] public EventCallback OnAnalyzeSelected { get; set; }

    /// <summary>
    /// Evento analizza tutti
    /// </summary>
    [Parameter] public EventCallback OnAnalyzeAll { get; set; }

    /// <summary>
    /// Evento toggle skip
    /// </summary>
    [Parameter] public EventCallback OnSkip { get; set; }

    /// <summary>
    /// Evento merge selezionato
    /// </summary>
    [Parameter] public EventCallback OnMergeSelected { get; set; }

    /// <summary>
    /// Evento merge tutti
    /// </summary>
    [Parameter] public EventCallback OnMergeAll { get; set; }

    /// <summary>
    /// Evento stop operazione
    /// </summary>
    [Parameter] public EventCallback OnStop { get; set; }

    /// <summary>
    /// Evento mostra configurazione
    /// </summary>
    [Parameter] public EventCallback OnShowConfig { get; set; }

    /// <summary>
    /// Modalita' corrente
    /// </summary>
    [Parameter] public string CurrentMode { get; set; }
}
