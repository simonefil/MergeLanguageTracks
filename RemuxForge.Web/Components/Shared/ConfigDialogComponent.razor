    /// <summary>
    /// Precompila campi dalle opzioni correnti
    /// </summary>
    protected override void OnInitialized()
    {
        if (Options != null)
        {
            _isSplitMode = Options.Mode == RemuxForge.Core.Models.Options.MODE_SPLIT;
            _sourceFolder = Options.SourceFolder;
            _languageFolder = Options.LanguageFolder;
            _destFolder = Options.DestinationFolder;
            _overwrite = Options.Overwrite;
            _recursive = Options.Recursive;
            _targetLang = string.Join(",", Options.TargetLanguage);
            _audioCodec = string.Join(",", Options.AudioCodec);
            _keepSrcAudio = string.Join(",", Options.KeepSourceAudioLangs);
            _keepSrcCodec = string.Join(",", Options.KeepSourceAudioCodec);
            _keepSrcSub = string.Join(",", Options.KeepSourceSubtitleLangs);
            _subOnly = Options.SubOnly;
            _audioOnly = Options.AudioOnly;
            _speedCorrectionMode = !string.IsNullOrEmpty(Options.SpeedCorrectionMode) ? Options.SpeedCorrectionMode : Options.SPEED_CORRECTION_OFF;
            _manualStretchFactor = Options.ManualStretchFactor;
            _frameSync = Options.FrameSync;
            _deepAnalysis = Options.DeepAnalysis;
            _analysisCropSourcePx = Options.AnalysisCropSourcePx;
            _analysisCropLanguagePx = Options.AnalysisCropLanguagePx;
            _audioDelay = Options.AudioDelay.ToString();
            _subDelay = Options.SubtitleDelay.ToString();
            _audioSourceFillEnabled = Options.AudioSourceFillThresholdMs > 0 ||
                Options.AudioSourceFillLanguage.Length > 0 ||
                Options.AudioSourceFillStart ||
                Options.AudioSourceFillEnd ||
                Options.AudioSourceFillInsertSilence;
            _audioSourceFillThresholdMs = Options.AudioSourceFillThresholdMs.ToString();
            _audioSourceFillLanguage = Options.AudioSourceFillLanguage;
            _audioSourceFillStart = Options.AudioSourceFillStart;
            _audioSourceFillEnd = Options.AudioSourceFillEnd;
            _audioSourceFillInsertSilence = Options.AudioSourceFillInsertSilence;
            _matchPattern = Options.MatchPattern;
            _extensions = string.Join(",", Options.FileExtensions);

            _audioFormat = Options.AudioFormat;
            _audioProcessingScope = Options.AudioProcessingScope;
            _audioDownsample24To16 = Options.AudioDownsample24To16;
            _audioPeakNormalize = Options.AudioPeakNormalize;
            _audioPeakTargetDb = Options.AudioPeakTargetDb.ToString(System.Globalization.CultureInfo.InvariantCulture);
            _audioRenameScope = Options.AudioRenameScope;

            _encodingProfile = Options.EncodingProfileName;

            if (_isSplitMode)
            {
                _splitSource = Options.SourceFolder.Length > 0 ? Options.SourceFolder : Options.Split.SourcePath;
                _splitSourceRaw = Options.Split.SourceRaw;
                _splitOutputDir = Options.Split.OutputDir;
                _splitPattern = Options.Split.Pattern;
                _splitRanges = Options.Split.Ranges;
                _splitAt = Options.Split.SplitAt;
                _splitTrimStart = Options.Split.TrimStart;
                _splitTrimEnd = Options.Split.TrimEnd;
                _splitCutMode = DetectSplitCutMode(Options.Split);
                _splitOutputTemplate = Options.Split.OutputTemplate;
                _splitSnap = Options.Split.Snap;
                _splitForce = Options.Split.Force;
                _splitDryRun = Options.Split.DryRun || Options.DryRun;
                _splitLog = Options.Split.Log;
            }

            SetFieldHelp(_isSplitMode ? "split.source" : "remux.source");
        }
    }

    /// <summary>
    /// Applica le opzioni compilate e notifica il parent
    /// </summary>
    private void Apply()
    {
        Options opts = new Options();
        int audioDelay;
        int subDelay;
        int audioSourceFillThresholdMs = 0;
        double audioPeakTargetDb;
        string[] parts;
        string trimmed;
        OptionsValidationResult validation;

        _validationError = "";

        if (_isSplitMode)
        {
            ApplySplit();
            return;
        }

        if (!ValidateInput())
        {
            return;
        }

        opts.Mode = Options.MODE_REMUX;
        opts.SourceFolder = _sourceFolder;
        opts.LanguageFolder = _languageFolder;
        opts.DestinationFolder = _destFolder;
        opts.Overwrite = _overwrite;
        opts.Recursive = _recursive;

        // Parsing CSV
        ParseCsv(_targetLang, opts.TargetLanguage);
        ParseCsv(_audioCodec, opts.AudioCodec);
        ParseCsv(_keepSrcAudio, opts.KeepSourceAudioLangs);
        ParseCsv(_keepSrcCodec, opts.KeepSourceAudioCodec);
        ParseCsv(_keepSrcSub, opts.KeepSourceSubtitleLangs);

        opts.SubOnly = _subOnly;
        opts.AudioOnly = _audioOnly;
        opts.SpeedCorrectionMode = _speedCorrectionMode;
        opts.ManualStretchFactor = _manualStretchFactor.Trim();
        opts.FrameSync = _frameSync;
        opts.DeepAnalysis = _deepAnalysis;
        opts.AnalysisCropSourcePx = Options.NormalizeAnalysisCropPx(_analysisCropSourcePx);
        opts.AnalysisCropLanguagePx = Options.NormalizeAnalysisCropPx(_analysisCropLanguagePx);

        int.TryParse(_audioDelay, out audioDelay);
        opts.AudioDelay = audioDelay;
        int.TryParse(_subDelay, out subDelay);
        opts.SubtitleDelay = subDelay;
        if (_audioSourceFillEnabled)
        {
            int.TryParse(_audioSourceFillThresholdMs, out audioSourceFillThresholdMs);
            opts.AudioSourceFillThresholdMs = audioSourceFillThresholdMs;
            opts.AudioSourceFillLanguage = _audioSourceFillLanguage.Trim();
            opts.AudioSourceFillStart = _audioSourceFillStart;
            opts.AudioSourceFillEnd = _audioSourceFillEnd;
            opts.AudioSourceFillInsertSilence = _deepAnalysis && _audioSourceFillInsertSilence;
        }

        opts.MatchPattern = _matchPattern;

        // Estensioni
        opts.FileExtensions.Clear();
        parts = _extensions.Split(',');
        for (int i = 0; i < parts.Length; i++)
        {
            trimmed = parts[i].Trim().TrimStart('.');
            if (trimmed.Length > 0) { opts.FileExtensions.Add(trimmed); }
        }

        opts.AudioFormat = _audioFormat.Trim().ToLowerInvariant();
        opts.AudioProcessingScope = opts.AudioFormat.Length > 0 ? _audioProcessingScope : "disabled";
        opts.AudioDownsample24To16 = (opts.AudioFormat == "flac" || opts.AudioFormat == "lpcm") && opts.AudioProcessingScope != "disabled" && _audioDownsample24To16;
        opts.AudioPeakNormalize = opts.AudioFormat.Length > 0 && opts.AudioProcessingScope != "disabled" && _audioPeakNormalize;
        if (!double.TryParse(_audioPeakTargetDb, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out audioPeakTargetDb))
        {
            audioPeakTargetDb = -1.0;
        }
        opts.AudioPeakTargetDb = audioPeakTargetDb;
        opts.AudioRenameScope = _audioRenameScope;

        // Path mkvmerge da AppSettings (gestito nel dialog Percorsi tool)
        opts.MkvMergePath = AppSettingsService.Instance.Settings.Tools.MkvMergePath.Length > 0 ? AppSettingsService.Instance.Settings.Tools.MkvMergePath : "mkvmerge";
        opts.EncodingProfileName = _encodingProfile;

        validation = OptionsValidator.Validate(opts, false, false);
        if (!validation.IsValid)
        {
            _validationError = validation.ErrorMessage;
            return;
        }

        OnApply.InvokeAsync(opts);
    }

    /// <summary>
    /// Applica configurazione split e notifica il parent
    /// </summary>
    private void ApplySplit()
    {
        Options opts = new Options();
        OptionsValidationResult validation;
        string[] parts;
        string trimmed;

        if (!ValidateSplitInput())
        {
            return;
        }

        opts.Mode = RemuxForge.Core.Models.Options.MODE_SPLIT;
        opts.SourceFolder = _splitSource.Trim();
        opts.Recursive = _recursive;
        opts.DryRun = _splitDryRun;
        opts.Split.SourcePath = opts.SourceFolder;
        opts.Split.SourceRaw = _splitSourceRaw.Trim();
        opts.Split.OutputDir = _splitOutputDir.Trim();
        if (_splitCutMode == SPLIT_CUT_PATTERN)
        {
            opts.Split.Pattern = _splitPattern.Trim();
        }
        else if (_splitCutMode == SPLIT_CUT_RANGES)
        {
            opts.Split.Ranges = _splitRanges.Trim();
        }
        else if (_splitCutMode == SPLIT_CUT_SPLIT_AT)
        {
            opts.Split.SplitAt = _splitAt.Trim();
        }
        else if (_splitCutMode == SPLIT_CUT_TRIM)
        {
            opts.Split.TrimStart = _splitTrimStart.Trim();
            opts.Split.TrimEnd = _splitTrimEnd.Trim();
        }
        else if (_splitCutMode == SPLIT_CUT_CHAPTERS_EACH)
        {
            opts.Split.ChaptersEach = true;
        }
        opts.Split.OutputTemplate = _splitOutputTemplate.Trim();
        opts.Split.Snap = _splitSnap;
        opts.Split.Force = _splitForce;
        opts.Split.DryRun = _splitDryRun;
        opts.Split.Log = _splitLog.Trim();

        opts.FileExtensions.Clear();
        parts = _extensions.Split(',');
        for (int i = 0; i < parts.Length; i++)
        {
            trimmed = parts[i].Trim().TrimStart('.');
            if (trimmed.Length > 0) { opts.FileExtensions.Add(trimmed); }
        }

        validation = OptionsValidator.Validate(opts, false, false);
        if (!validation.IsValid)
        {
            _validationError = validation.ErrorMessage;
            return;
        }

        OnApply.InvokeAsync(opts);
    }

    /// <summary>
    /// Valida i campi prima di costruire Options
    /// </summary>
    /// <returns>True se i campi sono validi</returns>
    private bool ValidateInput()
    {
        List<string> errors = new List<string>();
        int audioSourceFillThresholdMs = 0;

        if (!int.TryParse(_audioDelay, out _))
        {
            errors.Add(AppText.T("web.config.validation.audioDelayInt"));
        }

        if (!int.TryParse(_subDelay, out _))
        {
            errors.Add(AppText.T("web.config.validation.subDelayInt"));
        }

        if (_audioSourceFillEnabled && !int.TryParse(_audioSourceFillThresholdMs, out audioSourceFillThresholdMs))
        {
            errors.Add(AppText.T("web.config.validation.audioSourceThresholdInt"));
        }
        else if (_audioSourceFillEnabled && audioSourceFillThresholdMs <= 0)
        {
            errors.Add(AppText.T("web.config.validation.audioSourceThresholdPositive"));
        }

        if (_audioSourceFillEnabled && _audioSourceFillLanguage.Trim().Length == 0)
        {
            errors.Add(AppText.T("web.config.validation.audioSourceLanguageRequired"));
        }

        if (_audioSourceFillEnabled && !_audioSourceFillStart && !_audioSourceFillEnd && !(_deepAnalysis && _audioSourceFillInsertSilence))
        {
            errors.Add(AppText.T("web.config.validation.audioSourceModeRequired"));
        }

        if (_audioSourceFillEnabled && _audioFormat.Length == 0)
        {
            errors.Add(AppText.T("web.config.validation.audioSourceFormatRequired"));
        }

        if (_audioSourceFillEnabled && _audioProcessingScope == "disabled")
        {
            errors.Add(AppText.T("web.config.validation.audioSourceScopeRequired"));
        }

        if (!Options.TryParseAnalysisCropPx(_analysisCropSourcePx, out _, out _, out _, out _))
        {
            errors.Add(AppText.T("web.config.validation.cropSourceInvalid"));
        }

        if (!Options.TryParseAnalysisCropPx(_analysisCropLanguagePx, out _, out _, out _, out _))
        {
            errors.Add(AppText.T("web.config.validation.cropLangInvalid"));
        }

        if (_audioFormat.Length > 0 && _audioProcessingScope != "disabled" && _audioPeakNormalize && !double.TryParse(_audioPeakTargetDb, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out _))
        {
            errors.Add(AppText.T("web.config.validation.normalizationTargetInvalid"));
        }

        if (errors.Count > 0)
        {
            _validationError = string.Join("\n", errors);
            return false;
        }

        return true;
    }

    /// <summary>
    /// Valida i campi split prima di costruire Options
    /// </summary>
    /// <returns>True se i campi sono validi</returns>
    private bool ValidateSplitInput()
    {
        List<string> errors = new List<string>();
        if (_splitSource.Trim().Length == 0)
        {
            errors.Add(AppText.T("web.config.validation.sourceRequired"));
        }

        if (_splitSourceRaw.Trim().Length > 0 && System.IO.Directory.Exists(_splitSourceRaw.Trim()))
        {
            errors.Add(AppText.T("web.config.validation.sourceRawMustBeFile"));
        }

        if (_splitCutMode.Length == 0)
        {
            errors.Add(AppText.T("web.config.validation.cutModeRequired"));
        }

        if (_splitCutMode == SPLIT_CUT_PATTERN && _splitPattern.Trim().Length == 0)
        {
            errors.Add(AppText.T("web.config.validation.patternRequired"));
        }

        if (_splitCutMode == SPLIT_CUT_RANGES && _splitRanges.Trim().Length == 0)
        {
            errors.Add(AppText.T("web.config.validation.rangesRequired"));
        }

        if (_splitCutMode == SPLIT_CUT_SPLIT_AT && _splitAt.Trim().Length == 0)
        {
            errors.Add(AppText.T("web.config.validation.splitAtRequired"));
        }

        if (_splitCutMode == SPLIT_CUT_TRIM && _splitTrimStart.Trim().Length == 0 && _splitTrimEnd.Trim().Length == 0)
        {
            errors.Add(AppText.T("web.config.validation.trimRequired"));
        }

        if (errors.Count > 0)
        {
            _validationError = string.Join("\n", errors);
            return false;
        }

        return true;
    }

    /// <summary>
    /// Parsa stringa CSV e popola lista
    /// </summary>
    /// <param name="text">Testo CSV</param>
    /// <param name="list">Lista destinazione</param>
    private void ParseCsv(string text, List<string> list)
    {
        string[] parts;
        string trimmed;

        list.Clear();
        if (!string.IsNullOrEmpty(text))
        {
            parts = text.Split(',');
            for (int i = 0; i < parts.Length; i++)
            {
                trimmed = parts[i].Trim();
                if (trimmed.Length > 0) { list.Add(trimmed); }
            }
        }
    }

    /// <summary>
    /// Aggiorna il pane help contestuale
    /// </summary>
    /// <param name="key">Chiave campo</param>
    private void SetFieldHelp(string key)
    {
        string titleKey = "web.config.help." + key + ".title";
        string textKey = "web.config.help." + key + ".text";
        _fieldHelpTitle = AppText.T(titleKey);
        _fieldHelpText = AppText.T(textKey);
    }

    /// <summary>
    /// Determina la modalita' di taglio configurata
    /// </summary>
    /// <param name="split">Opzioni split</param>
    /// <returns>Identificativo modalita' di taglio</returns>
    private string DetectSplitCutMode(MkvSplitOptions split)
    {
        if (split == null) { return ""; }
        if (split.Pattern.Length > 0) { return SPLIT_CUT_PATTERN; }
        if (split.Ranges.Length > 0) { return SPLIT_CUT_RANGES; }
        if (split.SplitAt.Length > 0) { return SPLIT_CUT_SPLIT_AT; }
        if (split.TrimStart.Length > 0 || split.TrimEnd.Length > 0) { return SPLIT_CUT_TRIM; }
        if (split.ChaptersEach) { return SPLIT_CUT_CHAPTERS_EACH; }
        return "";
    }

    /// <summary>
    /// Apre il dialog browse cartella per il campo specificato
    /// </summary>
    /// <param name="fieldIndex">Indice campo: 0=source, 1=lingua, 2=dest</param>
    private void BrowseFolder(int fieldIndex)
    {
        _browseFieldIndex = fieldIndex;
        _browseShowFiles = false;

        // Determina percorso iniziale dal campo corrente
        if (fieldIndex == 0) { _browseInitialPath = _sourceFolder; }
        else if (fieldIndex == 1) { _browseInitialPath = _languageFolder; }
        else if (fieldIndex == 2) { _browseInitialPath = _destFolder; }

        _showBrowse = true;
    }

    /// <summary>
    /// Apre il dialog browse per un campo split
    /// </summary>
    /// <param name="fieldIndex">Indice campo split</param>
    /// <param name="showFiles">Flag: mostra file selezionabili</param>
    private void BrowseSplit(int fieldIndex, bool showFiles, bool allowCurrentFolderSelection)
    {
        _browseFieldIndex = fieldIndex;
        _browseShowFiles = showFiles;
        _browseAllowCurrentFolderSelection = allowCurrentFolderSelection;

        if (fieldIndex == 10) { _browseInitialPath = _splitSource; }
        else if (fieldIndex == 11) { _browseInitialPath = _splitOutputDir; }
        else if (fieldIndex == 12) { _browseInitialPath = _splitSourceRaw; }

        _showBrowse = true;
    }

    /// <summary>
    /// Chiude il dialog browse cartella
    /// </summary>
    private void CloseBrowse()
    {
        _showBrowse = false;
    }

    /// <summary>
    /// Applica il percorso selezionato dal dialog browse
    /// </summary>
    /// <param name="selectedPath">Percorso selezionato</param>
    private void ApplyBrowse(string selectedPath)
    {
        _showBrowse = false;

        if (string.IsNullOrEmpty(selectedPath)) { return; }

        // Applica al campo corretto
        if (_browseFieldIndex == 0) { _sourceFolder = selectedPath; }
        else if (_browseFieldIndex == 1) { _languageFolder = selectedPath; }
        else if (_browseFieldIndex == 2) { _destFolder = selectedPath; }
        else if (_browseFieldIndex == 10) { _splitSource = selectedPath; }
        else if (_browseFieldIndex == 11) { _splitOutputDir = selectedPath; }
        else if (_browseFieldIndex == 12) { _splitSourceRaw = selectedPath; }
    }

    /// <summary>
    /// Gestisce cambio formato audio e pulisce opzioni dipendenti non piu' applicabili
    /// </summary>
    private void OnAudioFormatChanged(ChangeEventArgs args)
    {
        _audioFormat = args.Value != null ? args.Value.ToString().Trim().ToLowerInvariant() : "";
        if (_audioFormat.Length == 0)
        {
            _audioProcessingScope = "disabled";
            _audioDownsample24To16 = false;
            _audioPeakNormalize = false;
            ResetAudioSourceFill();
        }
        else if (_audioFormat != "flac" && _audioFormat != "lpcm")
        {
            _audioDownsample24To16 = false;
        }
    }

    /// <summary>
    /// Toggle frame-sync con mutua esclusione deep analysis
    /// </summary>
    private void ToggleFrameSync()
    {
        _frameSync = !_frameSync;
        if (_frameSync && _deepAnalysis)
        {
            _deepAnalysis = false;
        }
    }

    /// <summary>
    /// Toggle deep analysis con mutua esclusione frame-sync
    /// </summary>
    private void ToggleDeepAnalysis()
    {
        _deepAnalysis = !_deepAnalysis;
        if (_deepAnalysis && _frameSync)
        {
            _frameSync = false;
        }

        if (!_deepAnalysis)
        {
            _audioSourceFillInsertSilence = false;
        }
    }

    /// <summary>
    /// Toggle audio source fill e azzera lo stato nascosto quando viene disabilitato
    /// </summary>
    private void ToggleAudioSourceFill()
    {
        _audioSourceFillEnabled = !_audioSourceFillEnabled;
        if (!_audioSourceFillEnabled)
        {
            ResetAudioSourceFill();
        }
    }

    /// <summary>
    /// Azzera opzioni audio source fill
    /// </summary>
    private void ResetAudioSourceFill()
    {
        _audioSourceFillEnabled = false;
        _audioSourceFillThresholdMs = "0";
        _audioSourceFillLanguage = "";
        _audioSourceFillStart = false;
        _audioSourceFillEnd = false;
        _audioSourceFillInsertSilence = false;
    }

}
