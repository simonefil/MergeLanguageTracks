<div class="log-panel">
    <div class="mlt-panel-title">Log</div>
    <div class="mlt-panel-body">
        <pre>@LogText</pre>
    </div>
</div>

@code {
    /// <summary>
    /// Testo log da visualizzare
    /// </summary>
    [Parameter] public string LogText { get; set; }

    /// <summary>
    /// Runtime JS per auto-scroll
    /// </summary>
    [Inject] private IJSRuntime JsRuntime { get; set; }

    /// <summary>
    /// Auto-scroll del log alla fine dopo ogni render
    /// </summary>
    /// <param name="firstRender">True se primo render</param>
    protected override async System.Threading.Tasks.Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            await this.JsRuntime.InvokeVoidAsync("eval",
                "var el = document.querySelector('.log-panel .mlt-panel-body'); if(el) el.scrollTop = el.scrollHeight;");
        }
        catch
        {
            // Ignora errori JS durante dispose
        }
    }
}
