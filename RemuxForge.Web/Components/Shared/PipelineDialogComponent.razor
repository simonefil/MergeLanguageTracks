@using RemuxForge.Core

<div class="dialog-overlay visible" @onclick="OnClose">
    <div class="dialog-box" style="min-width: 40ch;" @onclick:stopPropagation="true">
        <div class="dialog-title">Pipeline</div>
        <div class="dialog-body" style="line-height: 1.6lh;">
            @for (int i = 0; i < _steps.Count; i++)
            {
                <div>@((i + 1).ToString()). @_steps[i]</div>
            }
        </div>
        <div class="dialog-footer">
            <button @onclick="OnClose">Chiudi</button>
        </div>
    </div>
</div>

@code {
    /// <summary>
    /// Evento chiusura dialog
    /// </summary>
    [Parameter] public EventCallback OnClose { get; set; }

    /// <summary>
    /// Opzioni correnti per generare gli step
    /// </summary>
    [Parameter] public Options Options { get; set; }

    /// <summary>
    /// Lista step pipeline calcolati
    /// </summary>
    private List<string> _steps;

    /// <summary>
    /// Calcola gli step della pipeline all'inizializzazione
    /// </summary>
    protected override void OnInitialized()
    {
        this._steps = ProcessingPipeline.GetPipelineSteps(this.Options);
    }
}
