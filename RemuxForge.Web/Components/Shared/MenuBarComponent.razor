<div class="menu-bar" tabindex="0">
    @for (int i = 0; i < _menus.Count; i++)
    {
        int idx = i;
        MenuDef menu = _menus[i];
        int mnemonicIndex = FindMnemonicIndex(menu.Label, menu.Mnemonic);
        <div class="menu-bar-item @(_activeIndex == idx ? "active" : "")"
             @onclick="() => ToggleMenu(idx)"
             @onmouseenter="() => HoverMenu(idx)">
            @if (mnemonicIndex >= 0)
            {
                @menu.Label.Substring(0, mnemonicIndex)<span class="menu-mnemonic">@menu.Label.Substring(mnemonicIndex, 1)</span>@menu.Label.Substring(mnemonicIndex + 1)
            }
            else
            {
                @menu.Label
            }
        </div>
    }
</div>

@if (_activeIndex >= 0)
{
    <div class="menu-overlay" @onclick="CloseMenu"></div>
    <div class="menu-dropdown" style="left: @(_menuPositions[_activeIndex])ch;">
        @for (int i = 0; i < _menus[_activeIndex].Items.Count; i++)
        {
            int itemIndex = i;
            MenuItemDef item = _menus[_activeIndex].Items[i];
            if (item.IsSeparator)
            {
                <hr />
            }
            else
            {
                <div class="menu-dropdown-item @(_activeItemIndex == itemIndex ? "active" : "")"
                     @onclick="() => InvokeItem(item)"
                     @onmouseenter="() => SetActiveItem(itemIndex)">
                    <span>@item.Label</span>
                    @if (item.Shortcut.Length > 0)
                    {
                        <span class="shortcut">@item.Shortcut</span>
                    }
                </div>
            }
        }
    </div>
}

@code {
    /// <summary>
    /// Definizione menu
    /// </summary>
    private class MenuDef
    {
        /// <summary>
        /// Etichetta del menu
        /// </summary>
        public string Label;

        /// <summary>
        /// Voci del menu
        /// </summary>
        public List<MenuItemDef> Items;

        /// <summary>
        /// Mnemonico tastiera per apertura con Option/Alt
        /// </summary>
        public string Mnemonic;
    }

    /// <summary>
    /// Definizione voce menu
    /// </summary>
    private class MenuItemDef
    {
        /// <summary>
        /// Etichetta della voce
        /// </summary>
        public string Label;

        /// <summary>
        /// Scorciatoia tastiera
        /// </summary>
        public string Shortcut;

        /// <summary>
        /// Callback azione
        /// </summary>
        public Action Callback;

        /// <summary>
        /// Flag separatore
        /// </summary>
        public bool IsSeparator;
    }

    /// <summary>
    /// Evento scan file
    /// </summary>
    [Parameter] public EventCallback OnScan { get; set; }

    /// <summary>
    /// Evento analizza selezionato
    /// </summary>
    [Parameter] public EventCallback OnAnalyzeSelected { get; set; }

    /// <summary>
    /// Evento analizza tutti
    /// </summary>
    [Parameter] public EventCallback OnAnalyzeAll { get; set; }

    /// <summary>
    /// Evento toggle skip
    /// </summary>
    [Parameter] public EventCallback OnSkip { get; set; }

    /// <summary>
    /// Evento merge selezionato
    /// </summary>
    [Parameter] public EventCallback OnMergeSelected { get; set; }

    /// <summary>
    /// Evento merge tutti
    /// </summary>
    [Parameter] public EventCallback OnMergeAll { get; set; }

    /// <summary>
    /// Evento richiesta stop operazione
    /// </summary>
    [Parameter] public EventCallback OnStop { get; set; }

    /// <summary>
    /// Evento mostra configurazione
    /// </summary>
    [Parameter] public EventCallback OnShowConfig { get; set; }

    /// <summary>
    /// Evento mostra percorsi tool
    /// </summary>
    [Parameter] public EventCallback OnShowToolPaths { get; set; }

    /// <summary>
    /// Evento mostra impostazioni audio
    /// </summary>
    [Parameter] public EventCallback OnShowAudioSettings { get; set; }

    /// <summary>
    /// Evento mostra impostazioni avanzate
    /// </summary>
    [Parameter] public EventCallback OnShowAdvancedSettings { get; set; }

    /// <summary>
    /// Evento mostra profili encoding
    /// </summary>
    [Parameter] public EventCallback OnShowEncodingProfiles { get; set; }

    /// <summary>
    /// Evento mostra info
    /// </summary>
    [Parameter] public EventCallback OnShowInfo { get; set; }

    /// <summary>
    /// Evento mostra pipeline
    /// </summary>
    [Parameter] public EventCallback OnShowPipeline { get; set; }

    /// <summary>
    /// Evento cambio tema
    /// </summary>
    [Parameter] public EventCallback<string> OnThemeChanged { get; set; }

    /// <summary>
    /// Tema corrente
    /// </summary>
    [Parameter] public string CurrentTheme { get; set; }

    /// <summary>
    /// Modalita' corrente
    /// </summary>
    [Parameter] public string CurrentMode { get; set; }

    /// <summary>
    /// Indice menu attualmente aperto (-1 = nessuno)
    /// </summary>
    private int _activeIndex = -1;

    /// <summary>
    /// Indice voce attiva nel menu aperto
    /// </summary>
    private int _activeItemIndex = -1;

    /// <summary>
    /// Lista definizioni menu
    /// </summary>
    private List<MenuDef> _menus;

    /// <summary>
    /// Posizioni orizzontali dei menu in unita' ch
    /// </summary>
    private List<int> _menuPositions;

    /// <summary>
    /// Inizializzazione definizioni menu e calcolo posizioni
    /// </summary>
    protected override void OnParametersSet()
    {
        if (this.CurrentMode == RemuxForge.Core.Models.Options.MODE_SPLIT)
        {
            this._menus = new List<MenuDef>
            {
                new MenuDef { Label = "File", Mnemonic = "F", Items = new List<MenuItemDef>
                {
                    new MenuItemDef { Label = "Configurazione Split", Shortcut = "F2", Callback = () => OnShowConfig.InvokeAsync() },
                }},
                new MenuDef { Label = "Azioni", Mnemonic = "A", Items = new List<MenuItemDef>
                {
                    new MenuItemDef { Label = "Scan input", Shortcut = "F5", Callback = () => OnScan.InvokeAsync() },
                    new MenuItemDef { Label = "Split tutti", Shortcut = "F10", Callback = () => OnMergeAll.InvokeAsync() },
                    new MenuItemDef { Label = "Stop", Shortcut = "F12", Callback = () => OnStop.InvokeAsync() },
                }},
                new MenuDef { Label = "Impostazioni", Mnemonic = "I", Items = new List<MenuItemDef>
                {
                    new MenuItemDef { Label = "Percorsi tool", Shortcut = "", Callback = () => OnShowToolPaths.InvokeAsync() },
                }},
                new MenuDef { Label = "Vista", Mnemonic = "V", Items = new List<MenuItemDef>
                {
                    new MenuItemDef { Label = "Pipeline...", Shortcut = "", Callback = () => OnShowPipeline.InvokeAsync() },
                }},
                new MenuDef { Label = "Tema", Mnemonic = "T", Items = new List<MenuItemDef>
                {
                    new MenuItemDef { Label = "Nord", Shortcut = "", Callback = () => OnThemeChanged.InvokeAsync("nord") },
                    new MenuItemDef { Label = "DOS Blue", Shortcut = "", Callback = () => OnThemeChanged.InvokeAsync("dos-blue") },
                    new MenuItemDef { Label = "Matrix", Shortcut = "", Callback = () => OnThemeChanged.InvokeAsync("matrix") },
                    new MenuItemDef { Label = "Cyberpunk", Shortcut = "", Callback = () => OnThemeChanged.InvokeAsync("cyberpunk") },
                    new MenuItemDef { Label = "Solarized Dark", Shortcut = "", Callback = () => OnThemeChanged.InvokeAsync("solarized-dark") },
                    new MenuItemDef { Label = "Solarized Light", Shortcut = "", Callback = () => OnThemeChanged.InvokeAsync("solarized-light") },
                    new MenuItemDef { Label = "Cybergum", Shortcut = "", Callback = () => OnThemeChanged.InvokeAsync("cybergum") },
                    new MenuItemDef { Label = "Everforest", Shortcut = "", Callback = () => OnThemeChanged.InvokeAsync("everforest") },
                }},
                new MenuDef { Label = "Aiuto", Mnemonic = "U", Items = new List<MenuItemDef>
                {
                    new MenuItemDef { Label = "Info", Shortcut = "", Callback = () => OnShowInfo.InvokeAsync() },
                }},
            };
        }
        else
        {
            this._menus = new List<MenuDef>
        {
            new MenuDef { Label = "File", Mnemonic = "F", Items = new List<MenuItemDef>
            {
                new MenuItemDef { Label = "Configurazione", Shortcut = "F2", Callback = () => OnShowConfig.InvokeAsync() },
            }},
            new MenuDef { Label = "Azioni", Mnemonic = "A", Items = new List<MenuItemDef>
            {
                new MenuItemDef { Label = "Scan file", Shortcut = "F5", Callback = () => OnScan.InvokeAsync() },
                new MenuItemDef { Label = "Analizza selezionato", Shortcut = "F6", Callback = () => OnAnalyzeSelected.InvokeAsync() },
                new MenuItemDef { Label = "Analizza tutti", Shortcut = "F7", Callback = () => OnAnalyzeAll.InvokeAsync() },
                new MenuItemDef { Label = "IsSeparator", IsSeparator = true, Shortcut = "", Callback = null },
                new MenuItemDef { Label = "Skip/Unskip", Shortcut = "F8", Callback = () => OnSkip.InvokeAsync() },
                new MenuItemDef { Label = "IsSeparator", IsSeparator = true, Shortcut = "", Callback = null },
                new MenuItemDef { Label = "Processa selezionato", Shortcut = "F9", Callback = () => OnMergeSelected.InvokeAsync() },
                new MenuItemDef { Label = "Processa tutti", Shortcut = "F10", Callback = () => OnMergeAll.InvokeAsync() },
                new MenuItemDef { Label = "Stop", Shortcut = "F12", Callback = () => OnStop.InvokeAsync() },
            }},
            new MenuDef { Label = "Impostazioni", Mnemonic = "I", Items = new List<MenuItemDef>
            {
                new MenuItemDef { Label = "Percorsi tool", Shortcut = "", Callback = () => OnShowToolPaths.InvokeAsync() },
                new MenuItemDef { Label = "Audio", Shortcut = "", Callback = () => OnShowAudioSettings.InvokeAsync() },
                new MenuItemDef { Label = "Impostazioni avanzate", Shortcut = "", Callback = () => OnShowAdvancedSettings.InvokeAsync() },
                new MenuItemDef { Label = "Profili encoding", Shortcut = "", Callback = () => OnShowEncodingProfiles.InvokeAsync() },
            }},
            new MenuDef { Label = "Vista", Mnemonic = "V", Items = new List<MenuItemDef>
            {
                new MenuItemDef { Label = "Pipeline...", Shortcut = "", Callback = () => OnShowPipeline.InvokeAsync() },
            }},
            new MenuDef { Label = "Tema", Mnemonic = "T", Items = new List<MenuItemDef>
            {
                new MenuItemDef { Label = "Nord", Shortcut = "", Callback = () => OnThemeChanged.InvokeAsync("nord") },
                new MenuItemDef { Label = "DOS Blue", Shortcut = "", Callback = () => OnThemeChanged.InvokeAsync("dos-blue") },
                new MenuItemDef { Label = "Matrix", Shortcut = "", Callback = () => OnThemeChanged.InvokeAsync("matrix") },
                new MenuItemDef { Label = "Cyberpunk", Shortcut = "", Callback = () => OnThemeChanged.InvokeAsync("cyberpunk") },
                new MenuItemDef { Label = "Solarized Dark", Shortcut = "", Callback = () => OnThemeChanged.InvokeAsync("solarized-dark") },
                new MenuItemDef { Label = "Solarized Light", Shortcut = "", Callback = () => OnThemeChanged.InvokeAsync("solarized-light") },
                new MenuItemDef { Label = "Cybergum", Shortcut = "", Callback = () => OnThemeChanged.InvokeAsync("cybergum") },
                new MenuItemDef { Label = "Everforest", Shortcut = "", Callback = () => OnThemeChanged.InvokeAsync("everforest") },
            }},
            new MenuDef { Label = "Aiuto", Mnemonic = "U", Items = new List<MenuItemDef>
            {
                new MenuItemDef { Label = "Info", Shortcut = "", Callback = () => OnShowInfo.InvokeAsync() },
            }},
        };
        }

        // Calcola posizioni orizzontali: ogni label + 2ch padding (1ch per lato)
        this._menuPositions = new List<int>();
        int pos = 0;
        for (int i = 0; i < this._menus.Count; i++)
        {
            this._menuPositions.Add(pos);
            // Larghezza = lunghezza label + 2 (padding 1ch per lato)
            pos = pos + this._menus[i].Label.Length + 2;
        }

        this.NormalizeActiveMenu();
    }

    /// <summary>
    /// Gestisce navigazione tastiera della menu bar
    /// </summary>
    /// <param name="key">Tasto premuto</param>
    /// <param name="ctrl">Flag Ctrl</param>
    /// <param name="shift">Flag Shift</param>
    /// <param name="alt">Flag Alt</param>
    /// <returns>True se il tasto e' stato gestito dal menu</returns>
    public bool HandleKeyboardKey(string key, bool ctrl, bool shift, bool alt)
    {
        bool result = false;
        int mnemonicIndex;

        if (this._menus == null || this._menus.Count == 0 || ctrl)
        {
            return result;
        }

        if (this._activeIndex >= 0)
        {
            result = true;
            if (key == "Escape" || key == "Alt")
            {
                this.CloseMenu();
            }
            else if (key == "ArrowRight")
            {
                this.MoveMenu(1);
            }
            else if (key == "ArrowLeft")
            {
                this.MoveMenu(-1);
            }
            else if (key == "ArrowDown")
            {
                this.MoveMenuItem(1);
            }
            else if (key == "ArrowUp")
            {
                this.MoveMenuItem(-1);
            }
            else if (key == "Home")
            {
                this.SetFirstSelectableItem();
            }
            else if (key == "End")
            {
                this.SetLastSelectableItem();
            }
            else if (key == "Enter" || key == " ")
            {
                this.InvokeActiveItem();
            }
            else if (alt && this.TryFindMenuMnemonic(key, out mnemonicIndex))
            {
                this.OpenMenu(mnemonicIndex);
            }
            else
            {
                result = false;
            }
        }
        else if (key == "Alt")
        {
            this.OpenMenu(0);
            result = true;
        }
        else if (alt && this.TryFindMenuMnemonic(key, out mnemonicIndex))
        {
            this.OpenMenu(mnemonicIndex);
            result = true;
        }

        return result;
    }

    /// <summary>
    /// Apre/chiude un menu per click
    /// </summary>
    /// <param name="index">Indice del menu</param>
    private void ToggleMenu(int index)
    {
        if (this._activeIndex == index)
        {
            this._activeIndex = -1;
            this._activeItemIndex = -1;
        }
        else
        {
            this.OpenMenu(index);
        }
    }

    /// <summary>
    /// Commuta menu al passaggio del mouse (solo se un menu e' gia' aperto)
    /// </summary>
    /// <param name="index">Indice del menu</param>
    private void HoverMenu(int index)
    {
        if (this._activeIndex >= 0)
        {
            this.OpenMenu(index);
        }
    }

    /// <summary>
    /// Chiude il menu attivo
    /// </summary>
    private void CloseMenu()
    {
        this._activeIndex = -1;
        this._activeItemIndex = -1;
    }

    /// <summary>
    /// Invoca callback voce menu e chiude
    /// </summary>
    /// <param name="item">Voce menu</param>
    private void InvokeItem(MenuItemDef item)
    {
        this.CloseMenu();
        if (item.Callback != null)
        {
            item.Callback.Invoke();
        }
    }

    /// <summary>
    /// Apre il menu indicato e seleziona la prima voce utile
    /// </summary>
    /// <param name="index">Indice menu</param>
    private void OpenMenu(int index)
    {
        if (index < 0 || index >= this._menus.Count)
        {
            return;
        }

        this._activeIndex = index;
        this.SetFirstSelectableItem();
    }

    /// <summary>
    /// Cambia menu attivo
    /// </summary>
    /// <param name="delta">Spostamento relativo</param>
    private void MoveMenu(int delta)
    {
        int index = this._activeIndex + delta;

        if (index < 0) { index = this._menus.Count - 1; }
        if (index >= this._menus.Count) { index = 0; }
        this.OpenMenu(index);
    }

    /// <summary>
    /// Cambia voce attiva nel menu aperto saltando separatori
    /// </summary>
    /// <param name="delta">Spostamento relativo</param>
    private void MoveMenuItem(int delta)
    {
        List<MenuItemDef> items;
        int index;
        int attempts = 0;

        if (this._activeIndex < 0 || this._activeIndex >= this._menus.Count)
        {
            return;
        }

        items = this._menus[this._activeIndex].Items;
        if (items.Count == 0)
        {
            this._activeItemIndex = -1;
            return;
        }

        index = this._activeItemIndex;
        if (index < 0)
        {
            index = delta >= 0 ? -1 : items.Count;
        }

        do
        {
            index += delta;
            if (index < 0) { index = items.Count - 1; }
            if (index >= items.Count) { index = 0; }
            attempts++;
        }
        while (attempts <= items.Count && items[index].IsSeparator);

        if (attempts <= items.Count)
        {
            this._activeItemIndex = index;
        }
    }

    /// <summary>
    /// Seleziona prima voce attivabile
    /// </summary>
    private void SetFirstSelectableItem()
    {
        this._activeItemIndex = this.FindSelectableItem(0, 1);
    }

    /// <summary>
    /// Seleziona ultima voce attivabile
    /// </summary>
    private void SetLastSelectableItem()
    {
        if (this._activeIndex < 0 || this._activeIndex >= this._menus.Count)
        {
            this._activeItemIndex = -1;
            return;
        }

        this._activeItemIndex = this.FindSelectableItem(this._menus[this._activeIndex].Items.Count - 1, -1);
    }

    /// <summary>
    /// Imposta voce attiva da hover mouse
    /// </summary>
    /// <param name="itemIndex">Indice voce</param>
    private void SetActiveItem(int itemIndex)
    {
        this._activeItemIndex = itemIndex;
    }

    /// <summary>
    /// Invoca la voce attiva
    /// </summary>
    private void InvokeActiveItem()
    {
        if (this._activeIndex < 0 || this._activeIndex >= this._menus.Count)
        {
            return;
        }

        if (this._activeItemIndex < 0 || this._activeItemIndex >= this._menus[this._activeIndex].Items.Count)
        {
            return;
        }

        if (this._menus[this._activeIndex].Items[this._activeItemIndex].IsSeparator)
        {
            return;
        }

        this.InvokeItem(this._menus[this._activeIndex].Items[this._activeItemIndex]);
    }

    /// <summary>
    /// Cerca una voce selezionabile nel menu attivo
    /// </summary>
    private int FindSelectableItem(int startIndex, int direction)
    {
        int result = -1;
        List<MenuItemDef> items;

        if (this._activeIndex < 0 || this._activeIndex >= this._menus.Count)
        {
            return result;
        }

        items = this._menus[this._activeIndex].Items;
        for (int i = startIndex; i >= 0 && i < items.Count; i += direction)
        {
            if (!items[i].IsSeparator)
            {
                result = i;
                break;
            }
        }

        return result;
    }

    /// <summary>
    /// Trova menu tramite mnemonico
    /// </summary>
    private bool TryFindMenuMnemonic(string key, out int index)
    {
        bool result = false;
        string normalizedKey = key != null ? key.ToUpperInvariant() : "";
        index = -1;

        if (normalizedKey.Length == 1)
        {
            for (int i = 0; i < this._menus.Count; i++)
            {
                if (string.Equals(this._menus[i].Mnemonic, normalizedKey, StringComparison.OrdinalIgnoreCase))
                {
                    index = i;
                    result = true;
                    break;
                }
            }
        }

        return result;
    }

    /// <summary>
    /// Trova posizione del mnemonico nella label
    /// </summary>
    /// <param name="label">Label menu</param>
    /// <param name="mnemonic">Mnemonico</param>
    /// <returns>Indice carattere, -1 se non trovato</returns>
    private int FindMnemonicIndex(string label, string mnemonic)
    {
        int result = -1;

        if (!string.IsNullOrEmpty(label) && !string.IsNullOrEmpty(mnemonic))
        {
            result = label.IndexOf(mnemonic, StringComparison.OrdinalIgnoreCase);
        }

        return result;
    }

    /// <summary>
    /// Normalizza indici attivi dopo rebuild menu
    /// </summary>
    private void NormalizeActiveMenu()
    {
        if (this._activeIndex >= this._menus.Count)
        {
            this.CloseMenu();
            return;
        }

        if (this._activeIndex >= 0 && this._activeItemIndex < 0)
        {
            this.SetFirstSelectableItem();
        }
    }
}
