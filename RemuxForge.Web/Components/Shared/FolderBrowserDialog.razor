<div class="dialog-overlay visible" @onclick="OnClose">
    <div class="dialog-box dialog-browse" @onclick:stopPropagation="true">
        <div class="dialog-title">@(ShowFiles ? "Seleziona file" : "Seleziona cartella")</div>
        <div class="dialog-body" style="display: flex; flex-direction: column; padding: 0;">

            @* Barra percorso con autocomplete (pattern Bivium) *@
            <div class="browse-path-bar">
                <div class="path-bar-edit">
                    <input type="text"
                           id="browse-path-input"
                           class="path-bar-input"
                           value="@_editPath"
                           @oninput="HandlePathInput"
                           @onkeydown="HandlePathKeyDown" />
                    @if (_autocompleteMatches.Count > 1)
                    {
                        <div class="path-autocomplete">
                            @for (int i = 0; i < _autocompleteMatches.Count; i++)
                            {
                                int idx = i;
                                <div class="path-autocomplete-item @(idx == _autocompleteIndex ? "active" : "")"
                                     @onmousedown="() => SelectAutocompleteItem(idx)">
                                    @_autocompleteMatches[idx]
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            @* Tabella 4 colonne come OpenDialog TUI *@
            <div class="browse-list">
                <table class="browse-table">
                    <thead>
                        <tr>
                            <th class="browse-col-name" @onclick="ToggleSort">Filename @(_sortAsc ? "(▲)" : "(▼)")</th>
                            <th class="browse-col-size">Size</th>
                            <th class="browse-col-date">Modified</th>
                            <th class="browse-col-type">Type</th>
                        </tr>
                    </thead>
                    <tbody>
                        @* Cartella parent *@
                        @if (_parentPath.Length > 0)
                        {
                            <tr class="browse-row" @ondblclick="() => NavigateTo(_parentPath)">
                                <td class="browse-col-name">..</td>
                                <td class="browse-col-size"></td>
                                <td class="browse-col-date"></td>
                                <td class="browse-col-type">&lt;Directory&gt;</td>
                            </tr>
                        }

                        @* Entries *@
                        @for (int i = 0; i < _entries.Count; i++)
                        {
                            int idx = i;
                            DirEntry entry = _entries[idx];
                            <tr class="browse-row @(idx == _selectedIndex ? "selected" : "")"
                                @onclick="() => SelectEntry(idx)"
                                @ondblclick="() => ActivateEntry(idx)">
                                <td class="browse-col-name">@(entry.IsDirectory ? "/" : "")@entry.Name</td>
                                <td class="browse-col-size">@entry.SizeText</td>
                                <td class="browse-col-date">@entry.ModifiedText</td>
                                <td class="browse-col-type">@entry.TypeText</td>
                            </tr>
                        }

                        @if (_entries.Count == 0 && _parentPath.Length == 0)
                        {
                            <tr>
                                <td colspan="4" style="color: var(--foreground2); text-align: center;">(vuoto)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* Campo Find *@
            <div class="browse-find-bar">
                <span class="browse-find-label">Find</span>
                <input class="form-input" value="@_filterText" @oninput="HandleFilterInput" />
            </div>

            @* Messaggio errore *@
            @if (_errorMessage.Length > 0)
            {
                <div class="browse-error">@_errorMessage</div>
            }
        </div>
        <div class="dialog-footer">
            <button @onclick="OnClose">Cancel</button>
            <button @onclick="Confirm">@(ShowFiles ? "Select file" : "Select folder")</button>
        </div>
    </div>
</div>

@code {
    /// <summary>
    /// Percorso iniziale da cui partire
    /// </summary>
    [Parameter] public string InitialPath { get; set; }

    /// <summary>
    /// Evento chiusura dialog
    /// </summary>
    [Parameter] public EventCallback OnClose { get; set; }

    /// <summary>
    /// Evento selezione cartella/file (restituisce percorso selezionato)
    /// </summary>
    [Parameter] public EventCallback<string> OnSelect { get; set; }

    /// <summary>
    /// Se true mostra anche i file e permette la selezione di un file
    /// </summary>
    [Parameter] public bool ShowFiles { get; set; }

    #region Variabili di classe

    /// <summary>
    /// Percorso corrente
    /// </summary>
    private string _currentPath = "";

    /// <summary>
    /// Testo editabile nella barra percorso
    /// </summary>
    private string _editPath = "";

    /// <summary>
    /// Percorso cartella parent
    /// </summary>
    private string _parentPath = "";

    /// <summary>
    /// Lista entries visibili (dopo filtro)
    /// </summary>
    private List<DirEntry> _entries = new List<DirEntry>();

    /// <summary>
    /// Lista entries completa (prima del filtro)
    /// </summary>
    private List<DirEntry> _allEntries = new List<DirEntry>();

    /// <summary>
    /// Indice entry selezionata
    /// </summary>
    private int _selectedIndex = -1;

    /// <summary>
    /// Messaggio errore
    /// </summary>
    private string _errorMessage = "";

    /// <summary>
    /// Testo filtro Find
    /// </summary>
    private string _filterText = "";

    /// <summary>
    /// Flag ordinamento crescente
    /// </summary>
    private bool _sortAsc = true;

    /// <summary>
    /// Match autocomplete correnti
    /// </summary>
    private List<string> _autocompleteMatches = new List<string>();

    /// <summary>
    /// Indice corrente nell'autocomplete
    /// </summary>
    private int _autocompleteIndex = 0;

    /// <summary>
    /// Directory parent usata per la sessione autocomplete corrente
    /// </summary>
    private string _autocompleteParentDir = "";

    /// <summary>
    /// Flag: directory iniziale gia' caricata
    /// </summary>
    private bool _loaded = false;

    #endregion

    #region Classe DirEntry

    /// <summary>
    /// Entry directory per la tabella
    /// </summary>
    private class DirEntry
    {
        /// <summary>
        /// Nome cartella
        /// </summary>
        public string Name = "";

        /// <summary>
        /// Percorso completo
        /// </summary>
        public string FullPath = "";

        /// <summary>
        /// Dimensione formattata
        /// </summary>
        public string SizeText = "";

        /// <summary>
        /// Data modifica formattata
        /// </summary>
        public string ModifiedText = "";

        /// <summary>
        /// Tipo entry
        /// </summary>
        public string TypeText = "";

        /// <summary>
        /// Flag: true se directory, false se file
        /// </summary>
        public bool IsDirectory = true;
    }

    #endregion

    #region Lifecycle

    /// <summary>
    /// Inizializza il dialog con il percorso iniziale (solo al primo caricamento)
    /// </summary>
    protected override void OnParametersSet()
    {
        // Evita reinizializzazione su ogni re-render del parent
        if (this._loaded)
        {
            return;
        }

        this._loaded = true;

        if (InitialPath != null && InitialPath.Length > 0)
        {
            if (System.IO.Directory.Exists(InitialPath))
            {
                _currentPath = InitialPath;
            }
            else if (System.IO.File.Exists(InitialPath))
            {
                // Percorso file: usa la cartella parent
                string dir = System.IO.Path.GetDirectoryName(InitialPath);
                _currentPath = dir != null && dir.Length > 0 ? dir : GetDefaultRoot();
            }
            else
            {
                _currentPath = GetDefaultRoot();
            }
        }
        else
        {
            _currentPath = GetDefaultRoot();
        }

        _editPath = _currentPath;
        this.LoadDirectory(_currentPath);
    }

    #endregion

    #region Navigazione directory

    /// <summary>
    /// Carica il contenuto della cartella specificata
    /// </summary>
    /// <param name="path">Percorso cartella</param>
    private void LoadDirectory(string path)
    {
        _errorMessage = "";
        _selectedIndex = -1;
        _filterText = "";
        _allEntries.Clear();
        _entries.Clear();

        try
        {
            System.IO.DirectoryInfo dirInfo = new System.IO.DirectoryInfo(path);

            if (!dirInfo.Exists)
            {
                _errorMessage = "Cartella non trovata: " + path;
                return;
            }

            _currentPath = dirInfo.FullName;
            _editPath = _currentPath;

            // Percorso parent
            if (dirInfo.Parent != null)
            {
                _parentPath = dirInfo.Parent.FullName;
            }
            else
            {
                _parentPath = "";
            }

            // Elenca sottocartelle
            System.IO.DirectoryInfo[] subDirs = dirInfo.GetDirectories();
            for (int i = 0; i < subDirs.Length; i++)
            {
                // Nascondi cartelle di sistema/nascoste
                if ((subDirs[i].Attributes & System.IO.FileAttributes.Hidden) != 0) { continue; }
                if ((subDirs[i].Attributes & System.IO.FileAttributes.System) != 0) { continue; }

                DirEntry entry = new DirEntry();
                entry.Name = subDirs[i].Name;
                entry.FullPath = subDirs[i].FullName;
                entry.SizeText = "";
                entry.ModifiedText = subDirs[i].LastWriteTime.ToString("yyyy-MM-ddTHH:mm:ss");
                entry.TypeText = "<Directory>";
                entry.IsDirectory = true;

                _allEntries.Add(entry);
            }

            // Elenca file (solo se ShowFiles e' attivo)
            if (this.ShowFiles)
            {
                System.IO.FileInfo[] files = dirInfo.GetFiles();
                for (int i = 0; i < files.Length; i++)
                {
                    if ((files[i].Attributes & System.IO.FileAttributes.Hidden) != 0) { continue; }
                    if ((files[i].Attributes & System.IO.FileAttributes.System) != 0) { continue; }

                    DirEntry fileEntry = new DirEntry();
                    fileEntry.Name = files[i].Name;
                    fileEntry.FullPath = files[i].FullName;
                    fileEntry.SizeText = FormatFileSize(files[i].Length);
                    fileEntry.ModifiedText = files[i].LastWriteTime.ToString("yyyy-MM-ddTHH:mm:ss");
                    fileEntry.TypeText = files[i].Extension.Length > 0 ? files[i].Extension : "File";
                    fileEntry.IsDirectory = false;

                    _allEntries.Add(fileEntry);
                }
            }

            // Ordina
            this.SortEntries();
            _entries = new List<DirEntry>(_allEntries);
        }
        catch (UnauthorizedAccessException)
        {
            _errorMessage = "Accesso negato: " + path;
        }
        catch (Exception ex)
        {
            _errorMessage = "Errore: " + ex.Message;
        }
    }

    /// <summary>
    /// Naviga alla cartella specificata
    /// </summary>
    /// <param name="path">Percorso completo</param>
    private void NavigateTo(string path)
    {
        this.LoadDirectory(path);
    }

    /// <summary>
    /// Seleziona una entry nella lista
    /// </summary>
    /// <param name="index">Indice nella lista filtrata</param>
    private void SelectEntry(int index)
    {
        _selectedIndex = index;
    }

    /// <summary>
    /// Attiva una entry (doppio click) - naviga nella cartella o conferma file
    /// </summary>
    /// <param name="index">Indice nella lista filtrata</param>
    private void ActivateEntry(int index)
    {
        if (index >= 0 && index < _entries.Count)
        {
            if (_entries[index].IsDirectory)
            {
                this.LoadDirectory(_entries[index].FullPath);
            }
            else
            {
                // Doppio click su file: conferma selezione
                this.OnSelect.InvokeAsync(_entries[index].FullPath);
            }
        }
    }

    /// <summary>
    /// Conferma selezione e notifica il parent
    /// </summary>
    private void Confirm()
    {
        if (this.ShowFiles && _selectedIndex >= 0 && _selectedIndex < _entries.Count && !_entries[_selectedIndex].IsDirectory)
        {
            // Modalita' file: restituisci il file selezionato
            this.OnSelect.InvokeAsync(_entries[_selectedIndex].FullPath);
        }
        else
        {
            // Modalita' cartella: restituisci la cartella corrente
            this.OnSelect.InvokeAsync(_currentPath);
        }
    }

    #endregion

    #region Ordinamento e filtro

    /// <summary>
    /// Ordina le entries per nome
    /// </summary>
    private void SortEntries()
    {
        if (_sortAsc)
        {
            _allEntries.Sort((DirEntry a, DirEntry b) => string.Compare(a.Name, b.Name, StringComparison.OrdinalIgnoreCase));
        }
        else
        {
            _allEntries.Sort((DirEntry a, DirEntry b) => string.Compare(b.Name, a.Name, StringComparison.OrdinalIgnoreCase));
        }
    }

    /// <summary>
    /// Inverte ordinamento
    /// </summary>
    private void ToggleSort()
    {
        _sortAsc = !_sortAsc;
        this.SortEntries();
        this.ApplyFilterInternal();
    }

    /// <summary>
    /// Gestisce input nel campo Find
    /// </summary>
    /// <param name="args">Evento change</param>
    private void HandleFilterInput(ChangeEventArgs args)
    {
        _filterText = args.Value.ToString();
        this.ApplyFilterInternal();
    }

    /// <summary>
    /// Filtra la lista entries in base al testo Find
    /// </summary>
    private void ApplyFilterInternal()
    {
        _selectedIndex = -1;

        if (_filterText == null || _filterText.Length == 0)
        {
            _entries = new List<DirEntry>(_allEntries);
            return;
        }

        _entries = new List<DirEntry>();
        string filter = _filterText.ToLowerInvariant();

        for (int i = 0; i < _allEntries.Count; i++)
        {
            if (_allEntries[i].Name.ToLowerInvariant().Contains(filter))
            {
                _entries.Add(_allEntries[i]);
            }
        }
    }

    #endregion

    #region Autocomplete percorso (pattern Bivium)

    /// <summary>
    /// Gestisce input testo nella barra percorso
    /// </summary>
    /// <param name="args">Evento change</param>
    private void HandlePathInput(ChangeEventArgs args)
    {
        _editPath = args.Value.ToString();

        // Azzera autocomplete quando l'utente digita
        _autocompleteMatches.Clear();
        _autocompleteIndex = 0;
    }

    /// <summary>
    /// Gestisce pressione tasti nella barra percorso
    /// </summary>
    /// <param name="args">Evento tastiera</param>
    private void HandlePathKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            // Naviga al percorso digitato
            _autocompleteMatches.Clear();
            string path = _editPath.Trim();

            if (path.Length > 0 && System.IO.Directory.Exists(path))
            {
                this.LoadDirectory(path);
            }
            else
            {
                _errorMessage = "Percorso non valido: " + path;
            }
        }
        else if (args.Key == "Tab")
        {
            // Autocomplete
            this.HandlePathAutocomplete();
        }
        else if (args.Key == "Escape")
        {
            // Azzera autocomplete
            _autocompleteMatches.Clear();
            _autocompleteIndex = 0;
        }
    }

    /// <summary>
    /// Gestisce Tab per autocomplete percorso
    /// </summary>
    private void HandlePathAutocomplete()
    {
        // Cicla match esistenti
        if (_autocompleteMatches.Count > 1)
        {
            _autocompleteIndex = (_autocompleteIndex + 1) % _autocompleteMatches.Count;
            string selected = _autocompleteMatches[_autocompleteIndex];
            _editPath = _autocompleteParentDir + selected + System.IO.Path.DirectorySeparatorChar;
            return;
        }

        // Parsa input: separa directory parent e prefisso
        string input = _editPath.TrimEnd('/', '\\');
        string parentDir = "";
        string prefix = "";
        int lastSep = input.LastIndexOfAny(new char[] { '/', '\\' });

        if (lastSep >= 0)
        {
            parentDir = input.Substring(0, lastSep + 1);
            prefix = input.Substring(lastSep + 1);
        }
        else
        {
            parentDir = _currentPath;
            if (!parentDir.EndsWith(System.IO.Path.DirectorySeparatorChar))
            {
                parentDir += System.IO.Path.DirectorySeparatorChar;
            }
            prefix = input;
        }

        if (!System.IO.Directory.Exists(parentDir))
        {
            return;
        }

        // Cerca sottocartelle che matchano il prefisso
        List<string> matches = new List<string>();

        try
        {
            System.IO.DirectoryInfo[] subDirs = new System.IO.DirectoryInfo(parentDir).GetDirectories();
            string prefixLower = prefix.ToLowerInvariant();

            for (int i = 0; i < subDirs.Length; i++)
            {
                if ((subDirs[i].Attributes & System.IO.FileAttributes.Hidden) != 0) { continue; }
                if ((subDirs[i].Attributes & System.IO.FileAttributes.System) != 0) { continue; }

                if (subDirs[i].Name.ToLowerInvariant().StartsWith(prefixLower))
                {
                    matches.Add(subDirs[i].Name);
                }
            }
        }
        catch
        {
            return;
        }

        if (matches.Count == 0)
        {
            return;
        }

        // Salva parent per il cycling
        _autocompleteParentDir = parentDir;

        if (matches.Count == 1)
        {
            // Match singolo: completa e chiudi dropdown
            _editPath = parentDir + matches[0] + System.IO.Path.DirectorySeparatorChar;
            _autocompleteMatches.Clear();
            _autocompleteIndex = 0;
        }
        else
        {
            // Match multipli: completa prefisso comune, mostra dropdown
            string commonPrefix = this.GetCommonPrefix(matches);
            _autocompleteMatches = matches;
            _autocompleteIndex = 0;
            _editPath = parentDir + commonPrefix;
        }
    }

    /// <summary>
    /// Trova il prefisso comune piu' lungo tra una lista di stringhe
    /// </summary>
    /// <param name="strings">Lista stringhe</param>
    /// <returns>Prefisso comune</returns>
    private string GetCommonPrefix(List<string> strings)
    {
        string result = strings[0];

        for (int i = 1; i < strings.Count; i++)
        {
            int len = Math.Min(result.Length, strings[i].Length);
            int j = 0;

            while (j < len && char.ToLowerInvariant(result[j]) == char.ToLowerInvariant(strings[i][j]))
            {
                j++;
            }

            result = result.Substring(0, j);
        }

        return result;
    }

    /// <summary>
    /// Seleziona un item dall'autocomplete dropdown
    /// </summary>
    /// <param name="index">Indice item selezionato</param>
    private void SelectAutocompleteItem(int index)
    {
        if (index >= 0 && index < _autocompleteMatches.Count)
        {
            string selected = _autocompleteMatches[index];
            _editPath = _autocompleteParentDir + selected + System.IO.Path.DirectorySeparatorChar;
            _autocompleteMatches.Clear();
            _autocompleteIndex = 0;

            // Naviga direttamente
            string path = _editPath.Trim();
            if (path.Length > 0 && System.IO.Directory.Exists(path))
            {
                this.LoadDirectory(path);
            }
        }
    }

    #endregion

    #region Utility

    /// <summary>
    /// Formatta dimensione file in formato leggibile
    /// </summary>
    /// <param name="bytes">Dimensione in byte</param>
    /// <returns>Stringa formattata</returns>
    private static string FormatFileSize(long bytes)
    {
        string result = "";

        if (bytes >= 1073741824)
        {
            result = (bytes / 1073741824.0).ToString("0.0") + " GB";
        }
        else if (bytes >= 1048576)
        {
            result = (bytes / 1048576.0).ToString("0.0") + " MB";
        }
        else if (bytes >= 1024)
        {
            result = (bytes / 1024.0).ToString("0.0") + " KB";
        }
        else
        {
            result = bytes + " B";
        }

        return result;
    }

    /// <summary>
    /// Restituisce la root di default del sistema
    /// </summary>
    /// <returns>Percorso root</returns>
    private string GetDefaultRoot()
    {
        string result = "/";

        if (System.Runtime.InteropServices.RuntimeInformation.IsOSPlatform(System.Runtime.InteropServices.OSPlatform.Windows))
        {
            result = @"C:\";
        }

        return result;
    }

    #endregion
}
