@page "/"
@rendermode InteractiveServer
@inject MergeOrchestrator Orchestrator
@inject SplitOrchestrator SplitOrchestrator
@implements IAsyncDisposable

<div class="rf-layout">

    @* Barra Menu *@
    <MenuBarComponent @ref="_menuBar"
                       OnScan="DoScan"
                       OnAnalyzeSelected="DoAnalyzeSelected"
                       OnAnalyzeAll="DoAnalyzeAll"
                       OnSkip="DoToggleSkip"
                       OnMergeSelected="DoMergeSelected"
                       OnMergeAll="DoMergeAll"
                       OnStop="DoStop"
                       OnShowConfig="ShowConfig"
                       OnShowToolPaths="ShowToolPaths"
                       OnShowAudioSettings="ShowAudioSettings"
                       OnShowAdvancedSettings="ShowAdvancedSettings"
                       OnShowEncodingProfiles="ShowEncodingProfiles"
                       OnShowInfo="ShowInfo"
                       OnShowPipeline="ShowPipeline"
                       OnThemeChanged="ChangeTheme"
                       CurrentTheme="@_currentTheme"
                       CurrentMode="@_currentMode" />

    <div class="mode-switch">
        <button class="@(_currentMode == RemuxForge.Core.Models.Options.MODE_REMUX ? "active" : "")" @onclick="@(() => SwitchMode(RemuxForge.Core.Models.Options.MODE_REMUX))">Remux</button>
        <span class="mode-switch-separator">|</span>
        <button class="@(_currentMode == RemuxForge.Core.Models.Options.MODE_SPLIT ? "active" : "")" @onclick="@(() => SwitchMode(RemuxForge.Core.Models.Options.MODE_SPLIT))">Split</button>
    </div>

    @* Area Pannelli *@
    @if (_currentMode == RemuxForge.Core.Models.Options.MODE_SPLIT)
    {
        <div class="panels-area">
            <div class="rf-panel">
                <div class="rf-panel-title">Input</div>
                <div class="rf-panel-body split-input-body">
                    <table class="episode-table split-table">
                        <thead>
                            <tr><th>File</th><th>Status</th></tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < _splitRecords.Count; i++)
                            {
                                int idx = i;
                                MkvSplitRecord rec = _splitRecords[i];
                                <tr class="@(SplitOrchestrator.SelectedIndex == idx ? "selected" : "")" data-split-row-index="@idx" @onclick="() => SelectSplitRow(idx)">
                                    <td>@System.IO.Path.GetFileName(rec.InputFile)</td>
                                    <td>@rec.Status</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="rf-panel">
                <div class="rf-panel-title">Dettaglio file</div>
                <div class="rf-panel-body detail-content">
                    @if (_selectedSplitRecord == null)
                    {
                        <div class="empty-detail">Nessun file selezionato</div>
                    }
                    else
                    {
                        <div><span class="detail-label">File:</span> @_selectedSplitRecord.InputFile</div>
                        <div><span class="detail-label">Stato:</span> @_selectedSplitRecord.Status</div>
                        @if (_selectedSplitRecord.ErrorMessage.Length > 0)
                        {
                            <div><span class="detail-label">Errore:</span> @_selectedSplitRecord.ErrorMessage</div>
                        }
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="panels-area">
            <EpisodeTableComponent Records="@_records"
                                    SelectedIndex="@Orchestrator.SelectedIndex"
                                    SelectedIndices="@_selectedIndices"
                                    OnRowSelected="SelectRow"
                                    OnContextMenu="ShowContextMenu" />
            <DetailPanelComponent Record="@_selectedRecord" Options="@Orchestrator.CurrentOptions" />
        </div>
    }

    @* Pannello Log *@
    <LogPanelComponent LogText="@(_currentMode == RemuxForge.Core.Models.Options.MODE_SPLIT ? SplitOrchestrator.LogText : Orchestrator.LogText)" JsModule="@_jsModule" />

    @* Avanzamento *@
    <ProgressPanelComponent Progress="@(_currentMode == RemuxForge.Core.Models.Options.MODE_SPLIT ? SplitOrchestrator.Progress : Orchestrator.Progress)" />

    @* Barra di Stato *@
    <StatusBarComponent OnScan="DoScan"
                         OnAnalyzeSelected="DoAnalyzeSelected"
                         OnAnalyzeAll="DoAnalyzeAll"
                         OnSkip="DoToggleSkip"
                         OnMergeSelected="DoMergeSelected"
                         OnMergeAll="DoMergeAll"
                         OnStop="DoStop"
                         OnShowConfig="ShowConfig"
                         CurrentMode="@_currentMode" />
</div>

@* Dialog Configurazione *@
@if (_showConfig)
{
    <ConfigDialogComponent Options="@(_currentMode == RemuxForge.Core.Models.Options.MODE_SPLIT ? SplitOrchestrator.CurrentOptions : Orchestrator.CurrentOptions)"
                            OnClose="CloseConfig"
                            OnApply="ApplyConfig" />
}

@* Dialog Percorsi Tool *@
@if (_showToolPaths)
{
    <ToolPathsDialogComponent OnClose="CloseToolPaths" />
}

@* Dialog Impostazioni Audio *@
@if (_showAudioSettings)
{
    <AudioSettingsDialogComponent OnClose="CloseAudioSettings" />
}

@* Dialog Impostazioni Avanzate *@
@if (_showAdvancedSettings)
{
    <AdvancedSettingsDialogComponent OnClose="CloseAdvancedSettings" />
}

@* Dialog Delay *@
@if (_showDelay && _selectedRecord != null)
{
    <DelayDialogComponent Record="@_selectedRecord"
                           OnClose="CloseDelay"
                           OnApply="ApplyDelay" />
}

@* Dialog Profili Encoding *@
@if (_showEncodingProfiles)
{
    <EncodingProfilesDialog OnClose="CloseEncodingProfiles" />
}

@* Dialog Pipeline *@
@if (_showPipeline)
{
    <PipelineDialogComponent Options="@(_currentMode == RemuxForge.Core.Models.Options.MODE_SPLIT ? SplitOrchestrator.CurrentOptions : Orchestrator.CurrentOptions)" OnClose="ClosePipeline" />
}

@* Dialog Info *@
@if (_showInfo)
{
    <InfoDialogComponent OnClose="CloseInfo" />
}

@* Context Menu Episodio *@
@if (_showContextMenu && _contextMenuItems != null)
{
    <ContextMenuComponent Items="@_contextMenuItems"
                           X="@_contextMenuX"
                           Y="@_contextMenuY"
                           SelectedIndex="@_contextMenuSelectedIndex"
                           OnClose="CloseContextMenu"
                           OnActiveChanged="SetContextMenuActiveIndex"
                           OnSelect="HandleContextMenuSelect" />
}

@* Dialog MediaInfo *@
@if (_showMediaInfo)
{
    <MediaInfoDialogComponent Title="@_mediaInfoTitle"
                               Report="@_mediaInfoReport"
                               JsModule="@_jsModule"
                               OnClose="CloseMediaInfo" />
}
