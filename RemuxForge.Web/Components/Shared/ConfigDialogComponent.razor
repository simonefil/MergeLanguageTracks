<div class="dialog-overlay visible" @onclick="OnClose">
    <div class="dialog-box config-dialog-box" @onclick:stopPropagation="true">
        <div class="dialog-title">@AppText.T("web.config.title")</div>
        <div class="dialog-body config-dialog-body">
            <div class="config-form-pane">
            @if (_isSplitMode)
            {
                @* Sorgente Split *@
                <div class="form-section">@AppText.T("web.config.section.splitSource")</div>
                <div class="form-row">
                    <span class="form-label">@AppText.T("web.config.label.sourceRequired")</span>
                    <input class="form-input" @bind="_splitSource" @onfocus="@(() => SetFieldHelp("split.source"))" @onmouseenter="@(() => SetFieldHelp("split.source"))" />
                    <span class="btn-browse" @onclick="() => BrowseSplit(10, true, true)">[ .. ]</span>
                </div>
                <div class="form-row">
                    <span class="form-label">@AppText.T("web.config.label.output")</span>
                    <input class="form-input" @bind="_splitOutputDir" @onfocus="@(() => SetFieldHelp("split.output"))" @onmouseenter="@(() => SetFieldHelp("split.output"))" />
                    <span class="btn-browse" @onclick="() => BrowseSplit(11, false, true)">[ .. ]</span>
                </div>
                <div class="form-row">
                    <span class="form-label">@AppText.T("web.config.label.sourceRaw")</span>
                    <input class="form-input" @bind="_splitSourceRaw" @onfocus="@(() => SetFieldHelp("split.sourceRaw"))" @onmouseenter="@(() => SetFieldHelp("split.sourceRaw"))" />
                    <span class="btn-browse" @onclick="() => BrowseSplit(12, true, false)">[ .. ]</span>
                </div>
                <div class="form-row">
                    <span class="ui-toggle" @onclick="() => _recursive = !_recursive" @onmouseenter="@(() => SetFieldHelp("split.recursive"))">@(_recursive ? "[X]" : "[ ]") @AppText.T("web.config.toggle.recursive")</span>
                    <span class="ui-toggle" style="margin-left: 2ch;" @onclick="() => _splitForce = !_splitForce" @onmouseenter="@(() => SetFieldHelp("split.force"))">@(_splitForce ? "[X]" : "[ ]") @AppText.T("web.config.toggle.force")</span>
                    <span class="ui-toggle" style="margin-left: 2ch;" @onclick="() => _splitDryRun = !_splitDryRun" @onmouseenter="@(() => SetFieldHelp("split.dryRun"))">@(_splitDryRun ? "[X]" : "[ ]") @AppText.T("web.config.toggle.dryRun")</span>
                </div>

                @* Modalita taglio *@
                <div class="form-section">@AppText.T("web.config.section.cutting")</div>
                <div class="form-row">
                    <span class="form-label">@AppText.T("web.config.label.modeRequired")</span>
                    <select class="form-input" style="width: 22ch;" @bind="_splitCutMode" @onfocus="@(() => SetFieldHelp("split.mode"))" @onmouseenter="@(() => SetFieldHelp("split.mode"))">
                        <option value="">@AppText.T("web.common.choose")</option>
                        <option value="@SPLIT_CUT_PATTERN">@AppText.T("web.config.option.chapterPattern")</option>
                        <option value="@SPLIT_CUT_RANGES">@AppText.T("web.config.option.ranges")</option>
                        <option value="@SPLIT_CUT_SPLIT_AT">@AppText.T("web.config.option.splitAt")</option>
                        <option value="@SPLIT_CUT_TRIM">@AppText.T("web.config.option.trim")</option>
                        <option value="@SPLIT_CUT_CHAPTERS_EACH">@AppText.T("web.config.option.chaptersEach")</option>
                    </select>
                </div>
                @if (_splitCutMode == SPLIT_CUT_PATTERN)
                {
                    <div class="form-row">
                        <span class="form-label">@AppText.T("web.config.label.patternRequired")</span>
                        <input class="form-input" @bind="_splitPattern" placeholder="5,5,5" @onfocus="@(() => SetFieldHelp("split.pattern"))" @onmouseenter="@(() => SetFieldHelp("split.pattern"))" />
                    </div>
                }
                else if (_splitCutMode == SPLIT_CUT_RANGES)
                {
                    <div class="form-row">
                        <span class="form-label">@AppText.T("web.config.label.rangesRequired")</span>
                        <input class="form-input" @bind="_splitRanges" placeholder="0-00:24:00.000,00:24:00.000-END" @onfocus="@(() => SetFieldHelp("split.ranges"))" @onmouseenter="@(() => SetFieldHelp("split.ranges"))" />
                    </div>
                }
                else if (_splitCutMode == SPLIT_CUT_SPLIT_AT)
                {
                    <div class="form-row">
                        <span class="form-label">@AppText.T("web.config.label.splitAtRequired")</span>
                        <input class="form-input" @bind="_splitAt" placeholder="00:24:00.000" @onfocus="@(() => SetFieldHelp("split.splitAt"))" @onmouseenter="@(() => SetFieldHelp("split.splitAt"))" />
                    </div>
                }
                else if (_splitCutMode == SPLIT_CUT_TRIM)
                {
                    <div class="form-row">
                        <span class="form-label">@AppText.T("web.config.label.trimStart")</span>
                        <input class="form-input" @bind="_splitTrimStart" @onfocus="@(() => SetFieldHelp("split.trimStart"))" @onmouseenter="@(() => SetFieldHelp("split.trimStart"))" />
                    </div>
                    <div class="form-row">
                        <span class="form-label">@AppText.T("web.config.label.trimEnd")</span>
                        <input class="form-input" @bind="_splitTrimEnd" @onfocus="@(() => SetFieldHelp("split.trimEnd"))" @onmouseenter="@(() => SetFieldHelp("split.trimEnd"))" />
                    </div>
                }
                else if (_splitCutMode == SPLIT_CUT_CHAPTERS_EACH)
                {
                }

                <div class="form-row">
                    <span class="form-label">@AppText.T("web.config.label.snap")</span>
                    <select class="form-input" style="width: 14ch;" @bind="_splitSnap" @onfocus="@(() => SetFieldHelp("split.snap"))" @onmouseenter="@(() => SetFieldHelp("split.snap"))">
                        <option value="@RemuxForge.Core.Models.MkvSplitSnapMode.Off">off</option>
                        <option value="@RemuxForge.Core.Models.MkvSplitSnapMode.Before">before</option>
                        <option value="@RemuxForge.Core.Models.MkvSplitSnapMode.After">after</option>
                        <option value="@RemuxForge.Core.Models.MkvSplitSnapMode.Nearest">nearest</option>
                    </select>
                </div>

                @* Naming *@
                <div class="form-section">@AppText.T("web.config.section.naming")</div>
                <div class="form-row">
                    <span class="form-label">@AppText.T("web.config.label.template")</span>
                    <input class="form-input" @bind="_splitOutputTemplate" placeholder="{source_name}.part{n:02d}.mkv" @onfocus="@(() => SetFieldHelp("split.template"))" @onmouseenter="@(() => SetFieldHelp("split.template"))" />
                </div>

                @* Opzioni *@
                <div class="form-section">@AppText.T("web.config.section.options")</div>
                <div class="form-row">
                    <span class="form-label">@AppText.T("web.config.label.extensions")</span>
                    <input class="form-input" @bind="_extensions" @onfocus="@(() => SetFieldHelp("split.extensions"))" @onmouseenter="@(() => SetFieldHelp("split.extensions"))" />
                </div>
            }
            else
            {
            @* Cartelle *@
            <div class="form-section">@AppText.T("web.config.section.folders")</div>
            <div class="form-row">
                <span class="form-label">@AppText.T("web.config.label.sourceRequired")</span>
                <input class="form-input" @bind="_sourceFolder" @onfocus="@(() => SetFieldHelp("remux.source"))" @onmouseenter="@(() => SetFieldHelp("remux.source"))" />
                <span class="btn-browse" @onclick="() => BrowseFolder(0)">[ .. ]</span>
            </div>
            <div class="form-row">
                <span class="form-label">@AppText.T("web.config.label.language")</span>
                <input class="form-input" @bind="_languageFolder" @onfocus="@(() => SetFieldHelp("remux.language"))" @onmouseenter="@(() => SetFieldHelp("remux.language"))" />
                <span class="btn-browse" @onclick="() => BrowseFolder(1)">[ .. ]</span>
            </div>
            <div class="form-row">
                <span class="form-label">@AppText.T("web.config.label.destination")@(_overwrite ? "" : "*"):</span>
                <input class="form-input" @bind="_destFolder" @onfocus="@(() => SetFieldHelp("remux.destination"))" @onmouseenter="@(() => SetFieldHelp("remux.destination"))" />
                <span class="btn-browse" @onclick="() => BrowseFolder(2)">[ .. ]</span>
            </div>
            <div class="form-row">
                <span class="ui-toggle" @onclick="() => _overwrite = !_overwrite" @onmouseenter="@(() => SetFieldHelp("remux.overwrite"))">@(_overwrite ? "[X]" : "[ ]") @AppText.T("web.config.toggle.overwrite")</span>
            </div>
            <div class="form-row">
                <span class="ui-toggle" @onclick="() => _recursive = !_recursive" @onmouseenter="@(() => SetFieldHelp("remux.recursive"))">@(_recursive ? "[X]" : "[ ]") @AppText.T("web.config.toggle.recursive")</span>
            </div>

            @* Lingua e Tracce *@
            <div class="form-section">@AppText.T("web.config.section.languageTracks")</div>
            <div class="form-row">
                <span class="form-label">@AppText.T("web.config.label.targetLanguage")</span>
                <input class="form-input" @bind="_targetLang" @onfocus="@(() => SetFieldHelp("remux.target"))" @onmouseenter="@(() => SetFieldHelp("remux.target"))" />
            </div>
            <div class="form-row">
                <span class="form-label">@AppText.T("web.config.label.audioCodec")</span>
                <input class="form-input" @bind="_audioCodec" @onfocus="@(() => SetFieldHelp("remux.audioCodec"))" @onmouseenter="@(() => SetFieldHelp("remux.audioCodec"))" />
            </div>
            <div class="form-row">
                <span class="form-label">@AppText.T("web.config.label.keepAudio")</span>
                <input class="form-input" @bind="_keepSrcAudio" @onfocus="@(() => SetFieldHelp("remux.keepAudio"))" @onmouseenter="@(() => SetFieldHelp("remux.keepAudio"))" />
            </div>
            <div class="form-row">
                <span class="form-label">@AppText.T("web.config.label.keepCodec")</span>
                <input class="form-input" @bind="_keepSrcCodec" @onfocus="@(() => SetFieldHelp("remux.keepCodec"))" @onmouseenter="@(() => SetFieldHelp("remux.keepCodec"))" />
            </div>
            <div class="form-row">
                <span class="form-label">@AppText.T("web.config.label.keepSub")</span>
                <input class="form-input" @bind="_keepSrcSub" @onfocus="@(() => SetFieldHelp("remux.keepSub"))" @onmouseenter="@(() => SetFieldHelp("remux.keepSub"))" />
            </div>
            <div class="form-row">
                <span class="ui-toggle" @onclick="() => _subOnly = !_subOnly" @onmouseenter="@(() => SetFieldHelp("remux.subOnly"))">@(_subOnly ? "[X]" : "[ ]") @AppText.T("web.config.toggle.subOnly")</span>
                <span class="ui-toggle" style="margin-left: 2ch;" @onclick="() => _audioOnly = !_audioOnly" @onmouseenter="@(() => SetFieldHelp("remux.audioOnly"))">@(_audioOnly ? "[X]" : "[ ]") @AppText.T("web.config.toggle.audioOnly")</span>
            </div>

            @* Sincronizzazione *@
            <div class="form-section">@AppText.T("web.config.section.sync")</div>
            <div class="form-row">
                <span class="form-label">@AppText.T("web.config.label.speed")</span>
                <select class="form-input" style="width: 14ch;" @bind="_speedCorrectionMode" @onfocus="@(() => SetFieldHelp("remux.speed"))" @onmouseenter="@(() => SetFieldHelp("remux.speed"))">
                    <option value="@Options.SPEED_CORRECTION_OFF">@AppText.T("web.config.option.off")</option>
                    <option value="@Options.SPEED_CORRECTION_AUTO">@AppText.T("web.config.option.auto")</option>
                    <option value="@Options.SPEED_CORRECTION_MANUAL">@AppText.T("web.config.option.manual")</option>
                </select>
                <span style="margin-left: 1ch;">@AppText.T("web.config.label.stretch")</span>
                <input class="form-input" style="width: 14ch;" @bind="_manualStretchFactor" @onfocus="@(() => SetFieldHelp("remux.stretch"))" @onmouseenter="@(() => SetFieldHelp("remux.stretch"))" />
            </div>
            <div class="form-row">
                <span class="ui-toggle" @onclick="ToggleFrameSync" @onmouseenter="@(() => SetFieldHelp("remux.framesync"))">@(_frameSync ? "[X]" : "[ ]") @AppText.T("web.config.toggle.frameSync")</span>
            </div>
            <div class="form-row">
                <span class="ui-toggle" @onclick="ToggleDeepAnalysis" @onmouseenter="@(() => SetFieldHelp("remux.deep"))">@(_deepAnalysis ? "[X]" : "[ ]") @AppText.T("web.config.toggle.deepAnalysis")</span>
            </div>
            <div class="form-row">
                <span class="form-label">@AppText.T("web.config.label.cropSource")</span>
                <input class="form-input" style="width: 18ch;" @bind="_analysisCropSourcePx" placeholder="L:R:T:B" @onfocus="@(() => SetFieldHelp("remux.cropSource"))" @onmouseenter="@(() => SetFieldHelp("remux.cropSource"))" />
                <span style="margin-left: 2ch;">@AppText.T("web.config.label.langShort")</span>
                <input class="form-input" style="width: 18ch;" @bind="_analysisCropLanguagePx" placeholder="L:R:T:B" @onfocus="@(() => SetFieldHelp("remux.cropLang"))" @onmouseenter="@(() => SetFieldHelp("remux.cropLang"))" />
            </div>
            <div class="form-row">
                <span class="form-label">@AppText.T("web.config.label.audioDelay")</span>
                <input class="form-input" style="width: 8ch;" @bind="_audioDelay" @onfocus="@(() => SetFieldHelp("remux.audioDelay"))" @onmouseenter="@(() => SetFieldHelp("remux.audioDelay"))" /> <span style="margin-left: 0.5ch;">ms</span>
            </div>
            <div class="form-row">
                <span class="form-label">@AppText.T("web.config.label.subDelay")</span>
                <input class="form-input" style="width: 8ch;" @bind="_subDelay" @onfocus="@(() => SetFieldHelp("remux.subDelay"))" @onmouseenter="@(() => SetFieldHelp("remux.subDelay"))" /> <span style="margin-left: 0.5ch;">ms</span>
            </div>

            @* Matching *@
            <div class="form-section">@AppText.T("web.config.section.matching")</div>
            <div class="form-row">
                <span class="form-label">@AppText.T("web.config.label.matchPattern")</span>
                <input class="form-input" @bind="_matchPattern" @onfocus="@(() => SetFieldHelp("remux.match"))" @onmouseenter="@(() => SetFieldHelp("remux.match"))" />
            </div>
            <div class="form-row">
                <span class="form-label">@AppText.T("web.config.label.extensions")</span>
                <input class="form-input" @bind="_extensions" @onfocus="@(() => SetFieldHelp("remux.extensions"))" @onmouseenter="@(() => SetFieldHelp("remux.extensions"))" />
            </div>

            @* Post-Processing audio *@
            <div class="form-section">@AppText.T("web.config.section.audioPost")</div>
            <div class="form-row">
                <span class="form-label">@AppText.T("web.config.label.audioFormat")@(_audioSourceFillEnabled ? "*" : ""):</span>
                <select class="form-input" style="width: 12ch;" value="@_audioFormat" @onchange="OnAudioFormatChanged" @onfocus="@(() => SetFieldHelp("remux.audioFormat"))" @onmouseenter="@(() => SetFieldHelp("remux.audioFormat"))">
                    <option value="">@AppText.T("web.common.no")</option>
                    <option value="flac">FLAC</option>
                    <option value="lpcm">LPCM</option>
                    <option value="aac">AAC</option>
                    <option value="opus">Opus</option>
                </select>
            </div>
            @if (_audioFormat.Length > 0)
            {
            <div class="form-row">
                <span class="form-label">@AppText.T("web.config.label.audioScope")@(_audioSourceFillEnabled ? "*" : ""):</span>
                <select class="form-input" style="width: 14ch;" @bind="_audioProcessingScope" @onfocus="@(() => SetFieldHelp("remux.audioScope"))" @onmouseenter="@(() => SetFieldHelp("remux.audioScope"))">
                    <option value="disabled">@AppText.T("web.config.option.disabled")</option>
                    <option value="lang">Lang</option>
                    <option value="all">@AppText.T("web.config.option.all")</option>
                </select>
            </div>
            }
            @if (_audioFormat.Length > 0)
            {
                <div class="form-row">
                    <span class="ui-toggle" @onclick="ToggleAudioSourceFill" @onmouseenter="@(() => SetFieldHelp("remux.audioSourceFill"))">@(_audioSourceFillEnabled ? "[X]" : "[ ]") @AppText.T("web.config.toggle.audioSourceFill")</span>
                </div>
            }
            @if (_audioFormat.Length > 0 && _audioSourceFillEnabled)
            {
            <div class="form-row">
                <span class="form-label">@AppText.T("web.config.label.thresholdRequired")</span>
                <input class="form-input" style="width: 8ch;" @bind="_audioSourceFillThresholdMs" @onfocus="@(() => SetFieldHelp("remux.audioSourceFillThreshold"))" @onmouseenter="@(() => SetFieldHelp("remux.audioSourceFillThreshold"))" /> <span style="margin-left: 0.5ch;">ms</span>
            </div>
            <div class="form-row">
                <span class="form-label">@AppText.T("web.config.label.sourceLanguageRequired")</span>
                <input class="form-input" style="width: 10ch;" @bind="_audioSourceFillLanguage" @onfocus="@(() => SetFieldHelp("remux.audioSourceFillLang"))" @onmouseenter="@(() => SetFieldHelp("remux.audioSourceFillLang"))" />
            </div>
            <div class="form-row">
                <span class="form-label">@AppText.T("web.config.label.modeRequired")</span>
                <span class="ui-toggle" @onclick="() => _audioSourceFillStart = !_audioSourceFillStart" @onmouseenter="@(() => SetFieldHelp("remux.audioSourceFillStart"))">@(_audioSourceFillStart ? "[X]" : "[ ]") @AppText.T("web.config.toggle.start")</span>
                <span class="ui-toggle" style="margin-left: 2ch;" @onclick="() => _audioSourceFillEnd = !_audioSourceFillEnd" @onmouseenter="@(() => SetFieldHelp("remux.audioSourceFillEnd"))">@(_audioSourceFillEnd ? "[X]" : "[ ]") @AppText.T("web.config.toggle.end")</span>
                @if (_deepAnalysis)
                {
                    <span class="ui-toggle" style="margin-left: 2ch;" @onclick="() => _audioSourceFillInsertSilence = !_audioSourceFillInsertSilence" @onmouseenter="@(() => SetFieldHelp("remux.audioSourceFillInsert"))">@(_audioSourceFillInsertSilence ? "[X]" : "[ ]") @AppText.T("web.config.toggle.insertSilence")</span>
                }
            </div>
            }
            @if ((_audioFormat == "flac" || _audioFormat == "lpcm") && _audioProcessingScope != "disabled")
            {
            <div class="form-row">
                <span class="ui-toggle" @onclick="() => _audioDownsample24To16 = !_audioDownsample24To16" @onmouseenter="@(() => SetFieldHelp("remux.audio24"))">@(_audioDownsample24To16 ? "[X]" : "[ ]") @AppText.T("web.config.toggle.audio24")</span>
            </div>
            }
            @if (_audioFormat.Length > 0 && _audioProcessingScope != "disabled")
            {
            <div class="form-row">
                <span class="ui-toggle" @onclick="() => _audioPeakNormalize = !_audioPeakNormalize" @onmouseenter="@(() => SetFieldHelp("remux.audioNormalize"))">@(_audioPeakNormalize ? "[X]" : "[ ]") @AppText.T("web.config.toggle.normalization")</span>
                @if (_audioPeakNormalize)
                {
                    <input class="form-input" style="width: 8ch;" @bind="_audioPeakTargetDb" @onfocus="@(() => SetFieldHelp("remux.audioNormalize"))" @onmouseenter="@(() => SetFieldHelp("remux.audioNormalize"))" />
                    <span>dB</span>
                }
            </div>
            }
            <div class="form-row">
                <span class="form-label">@AppText.T("web.config.label.audioRename")</span>
                <select class="form-input" style="width: 14ch;" @bind="_audioRenameScope" @onfocus="@(() => SetFieldHelp("remux.rename"))" @onmouseenter="@(() => SetFieldHelp("remux.rename"))">
                    <option value="disabled">@AppText.T("web.common.no")</option>
                    <option value="lang">Lang</option>
                    <option value="all">@AppText.T("web.config.option.all")</option>
                </select>
            </div>

            @* Post-Processing video *@
            <div class="form-section">@AppText.T("web.config.section.videoPost")</div>
            <div class="form-row">
                <span class="form-label">@AppText.T("web.config.label.videoEncoding")</span>
                <select class="form-input" style="width: 30ch;" @bind="_encodingProfile" @onfocus="@(() => SetFieldHelp("remux.encoding"))" @onmouseenter="@(() => SetFieldHelp("remux.encoding"))">
                    <option value="">@AppText.T("web.common.none")</option>
                    @for (int i = 0; i < AppSettingsService.Instance.Settings.EncodingProfiles.Count; i++)
                    {
                        <option value="@AppSettingsService.Instance.Settings.EncodingProfiles[i].Name">@AppSettingsService.Instance.Settings.EncodingProfiles[i].Name</option>
                    }
                </select>
            </div>
            }
            </div>
            <div class="config-help-pane">
                <div class="config-help-title">@_fieldHelpTitle</div>
                <div class="config-help-text">@_fieldHelpText</div>
            </div>
        </div>
        @if (_validationError.Length > 0)
        {
            <div style="padding: 0.5em 1em; color: var(--color-error); white-space: pre-line;">@_validationError</div>
        }
        <div class="dialog-footer">
            <button @onclick="Apply">@AppText.T("web.common.ok")</button>
            <button @onclick="OnClose">@AppText.T("web.common.cancel")</button>
        </div>
    </div>
</div>

@* Dialog browse cartella *@
@if (_showBrowse)
{
    <FolderBrowserDialog InitialPath="@_browseInitialPath"
                          ShowFiles="@_browseShowFiles"
                          AllowCurrentFolderSelection="@_browseAllowCurrentFolderSelection"
                          OnClose="CloseBrowse"
                          OnSelect="ApplyBrowse" />
}

@code {
    #region Costanti

    /// <summary>
    /// Split per pattern capitoli
    /// </summary>
    private const string SPLIT_CUT_PATTERN = "pattern";

    /// <summary>
    /// Split per range espliciti
    /// </summary>
    private const string SPLIT_CUT_RANGES = "ranges";

    /// <summary>
    /// Split per punti di taglio
    /// </summary>
    private const string SPLIT_CUT_SPLIT_AT = "split-at";

    /// <summary>
    /// Trim singolo segmento
    /// </summary>
    private const string SPLIT_CUT_TRIM = "trim";

    /// <summary>
    /// Split capitolo per capitolo
    /// </summary>
    private const string SPLIT_CUT_CHAPTERS_EACH = "chapters-each";

    #endregion

    /// <summary>
    /// Opzioni correnti da precompilare
    /// </summary>
    [Parameter] public Options Options { get; set; }

    /// <summary>
    /// Evento chiusura dialog
    /// </summary>
    [Parameter] public EventCallback OnClose { get; set; }

    /// <summary>
    /// Evento applicazione opzioni
    /// </summary>
    [Parameter] public EventCallback<Options> OnApply { get; set; }

    /// <summary>
    /// Flag: mostra dialog browse cartella
    /// </summary>
    private bool _showBrowse;

    /// <summary>
    /// Percorso iniziale per il dialog browse
    /// </summary>
    private string _browseInitialPath = "";

    /// <summary>
    /// Flag: il dialog browse deve mostrare file selezionabili
    /// </summary>
    private bool _browseShowFiles;

    /// <summary>
    /// Flag: il dialog browse puo' confermare la cartella corrente
    /// </summary>
    private bool _browseAllowCurrentFolderSelection = true;

    /// <summary>
    /// Indice campo destinazione del browse: 0=source, 1=lingua, 2=dest
    /// </summary>
    private int _browseFieldIndex = -1;

    /// <summary>
    /// Flag: configurazione modalita' split
    /// </summary>
    private bool _isSplitMode;

    /// <summary>
    /// Cartella sorgente
    /// </summary>
    private string _sourceFolder = "";

    /// <summary>
    /// Cartella lingua
    /// </summary>
    private string _languageFolder = "";

    /// <summary>
    /// Cartella destinazione
    /// </summary>
    private string _destFolder = "";

    /// <summary>
    /// Flag sovrascrivi sorgente
    /// </summary>
    private bool _overwrite;

    /// <summary>
    /// Flag ricorsivo
    /// </summary>
    private bool _recursive = true;

    /// <summary>
    /// Lingua target (CSV)
    /// </summary>
    private string _targetLang = "";

    /// <summary>
    /// Codec audio (CSV)
    /// </summary>
    private string _audioCodec = "";

    /// <summary>
    /// Lingue audio sorgente da mantenere (CSV)
    /// </summary>
    private string _keepSrcAudio = "";

    /// <summary>
    /// Codec audio sorgente da mantenere (CSV)
    /// </summary>
    private string _keepSrcCodec = "";

    /// <summary>
    /// Sottotitoli sorgente da mantenere (CSV)
    /// </summary>
