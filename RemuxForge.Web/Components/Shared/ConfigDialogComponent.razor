    /// <summary>
    /// Determina la modalita' di taglio configurata
    /// </summary>
    /// <param name="split">Opzioni split</param>
    /// <returns>Identificativo modalita' di taglio</returns>
    private string DetectSplitCutMode(MkvSplitOptions split)
    {
        if (split == null) { return ""; }
        if (split.Pattern.Length > 0) { return SPLIT_CUT_PATTERN; }
        if (split.Ranges.Length > 0) { return SPLIT_CUT_RANGES; }
        if (split.SplitAt.Length > 0) { return SPLIT_CUT_SPLIT_AT; }
        if (split.TrimStart.Length > 0 || split.TrimEnd.Length > 0) { return SPLIT_CUT_TRIM; }
        if (split.ChaptersEach) { return SPLIT_CUT_CHAPTERS_EACH; }
        return "";
    }

    /// <summary>
    /// Apre il dialog browse cartella per il campo specificato
    /// </summary>
    /// <param name="fieldIndex">Indice campo: 0=source, 1=lingua, 2=dest</param>
    private void BrowseFolder(int fieldIndex)
    {
        _browseFieldIndex = fieldIndex;
        _browseShowFiles = false;

        // Determina percorso iniziale dal campo corrente
        if (fieldIndex == 0) { _browseInitialPath = _sourceFolder; }
        else if (fieldIndex == 1) { _browseInitialPath = _languageFolder; }
        else if (fieldIndex == 2) { _browseInitialPath = _destFolder; }

        _showBrowse = true;
    }

    /// <summary>
    /// Apre il dialog browse per un campo split
    /// </summary>
    /// <param name="fieldIndex">Indice campo split</param>
    /// <param name="showFiles">Flag: mostra file selezionabili</param>
    private void BrowseSplit(int fieldIndex, bool showFiles, bool allowCurrentFolderSelection)
    {
        _browseFieldIndex = fieldIndex;
        _browseShowFiles = showFiles;
        _browseAllowCurrentFolderSelection = allowCurrentFolderSelection;

        if (fieldIndex == 10) { _browseInitialPath = _splitSource; }
        else if (fieldIndex == 11) { _browseInitialPath = _splitOutputDir; }
        else if (fieldIndex == 12) { _browseInitialPath = _splitSourceRaw; }

        _showBrowse = true;
    }

    /// <summary>
    /// Chiude il dialog browse cartella
    /// </summary>
    private void CloseBrowse()
    {
        _showBrowse = false;
    }

    /// <summary>
    /// Applica il percorso selezionato dal dialog browse
    /// </summary>
    /// <param name="selectedPath">Percorso selezionato</param>
    private void ApplyBrowse(string selectedPath)
    {
        _showBrowse = false;

        if (string.IsNullOrEmpty(selectedPath)) { return; }

        // Applica al campo corretto
        if (_browseFieldIndex == 0) { _sourceFolder = selectedPath; }
        else if (_browseFieldIndex == 1) { _languageFolder = selectedPath; }
        else if (_browseFieldIndex == 2) { _destFolder = selectedPath; }
        else if (_browseFieldIndex == 10) { _splitSource = selectedPath; }
        else if (_browseFieldIndex == 11) { _splitOutputDir = selectedPath; }
        else if (_browseFieldIndex == 12) { _splitSourceRaw = selectedPath; }
    }

    /// <summary>
    /// Gestisce cambio formato audio e pulisce opzioni dipendenti non piu' applicabili
    /// </summary>
    private void OnAudioFormatChanged(ChangeEventArgs args)
    {
        _audioFormat = args.Value != null ? args.Value.ToString().Trim().ToLowerInvariant() : "";
        if (_audioFormat.Length == 0)
        {
            _audioProcessingScope = "disabled";
            _audioDownsample24To16 = false;
            _audioPeakNormalize = false;
            ResetAudioSourceFill();
        }
        else if (_audioFormat != "flac" && _audioFormat != "lpcm")
        {
            _audioDownsample24To16 = false;
        }
    }

    /// <summary>
    /// Toggle frame-sync con mutua esclusione deep analysis
    /// </summary>
    private void ToggleFrameSync()
    {
        _frameSync = !_frameSync;
        if (_frameSync && _deepAnalysis)
        {
            _deepAnalysis = false;
        }
    }

    /// <summary>
    /// Toggle deep analysis con mutua esclusione frame-sync
    /// </summary>
    private void ToggleDeepAnalysis()
    {
        _deepAnalysis = !_deepAnalysis;
        if (_deepAnalysis && _frameSync)
        {
            _frameSync = false;
        }

        if (!_deepAnalysis)
        {
            _audioSourceFillInsertSilence = false;
        }
    }

    /// <summary>
    /// Toggle audio source fill e azzera lo stato nascosto quando viene disabilitato
    /// </summary>
    private void ToggleAudioSourceFill()
    {
        _audioSourceFillEnabled = !_audioSourceFillEnabled;
        if (!_audioSourceFillEnabled)
        {
            ResetAudioSourceFill();
        }
    }

    /// <summary>
    /// Azzera opzioni audio source fill
    /// </summary>
    private void ResetAudioSourceFill()
    {
        _audioSourceFillEnabled = false;
        _audioSourceFillThresholdMs = "0";
        _audioSourceFillLanguage = "";
        _audioSourceFillStart = false;
        _audioSourceFillEnd = false;
        _audioSourceFillInsertSilence = false;
    }

}
