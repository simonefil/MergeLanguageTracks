<div class="dialog-overlay visible" @onclick="OnClose">
    <div class="dialog-box config-dialog-box" @onclick:stopPropagation="true">
        <div class="dialog-title">Configurazione</div>
        <div class="dialog-body config-dialog-body">
            <div class="config-form-pane">
            @if (_isSplitMode)
            {
                @* Sorgente Split *@
                <div class="form-section">== Sorgente Split ==</div>
                <div class="form-row">
                    <span class="form-label">Source*:</span>
                    <input class="form-input" @bind="_splitSource" @onfocus="@(() => SetFieldHelp("split.source"))" @onmouseenter="@(() => SetFieldHelp("split.source"))" />
                    <span class="btn-browse" @onclick="() => BrowseSplit(10, true, true)">[ .. ]</span>
                </div>
                <div class="form-row">
                    <span class="form-label">Output:</span>
                    <input class="form-input" @bind="_splitOutputDir" @onfocus="@(() => SetFieldHelp("split.output"))" @onmouseenter="@(() => SetFieldHelp("split.output"))" />
                    <span class="btn-browse" @onclick="() => BrowseSplit(11, false, true)">[ .. ]</span>
                </div>
                <div class="form-row">
                    <span class="form-label">Source raw:</span>
                    <input class="form-input" @bind="_splitSourceRaw" @onfocus="@(() => SetFieldHelp("split.sourceRaw"))" @onmouseenter="@(() => SetFieldHelp("split.sourceRaw"))" />
                    <span class="btn-browse" @onclick="() => BrowseSplit(12, true, false)">[ .. ]</span>
                </div>
                <div class="form-row">
                    <span class="ui-toggle" @onclick="() => _recursive = !_recursive" @onmouseenter="@(() => SetFieldHelp("split.recursive"))">@(_recursive ? "[X]" : "[ ]") Ricorsivo</span>
                    <span class="ui-toggle" style="margin-left: 2ch;" @onclick="() => _splitForce = !_splitForce" @onmouseenter="@(() => SetFieldHelp("split.force"))">@(_splitForce ? "[X]" : "[ ]") Force</span>
                    <span class="ui-toggle" style="margin-left: 2ch;" @onclick="() => _splitDryRun = !_splitDryRun" @onmouseenter="@(() => SetFieldHelp("split.dryRun"))">@(_splitDryRun ? "[X]" : "[ ]") Dry-run</span>
                </div>

                @* Modalita taglio *@
                <div class="form-section">== Taglio ==</div>
                <div class="form-row">
                    <span class="form-label">Modalita*:</span>
                    <select class="form-input" style="width: 22ch;" @bind="_splitCutMode" @onfocus="@(() => SetFieldHelp("split.mode"))" @onmouseenter="@(() => SetFieldHelp("split.mode"))">
                        <option value="">(scegliere)</option>
                        <option value="@SPLIT_CUT_PATTERN">Pattern capitoli</option>
                        <option value="@SPLIT_CUT_RANGES">Ranges</option>
                        <option value="@SPLIT_CUT_SPLIT_AT">Split at</option>
                        <option value="@SPLIT_CUT_TRIM">Trim</option>
                        <option value="@SPLIT_CUT_CHAPTERS_EACH">Chapters each</option>
                    </select>
                </div>
                @if (_splitCutMode == SPLIT_CUT_PATTERN)
                {
                    <div class="form-row">
                        <span class="form-label">Pattern*:</span>
                        <input class="form-input" @bind="_splitPattern" placeholder="5,5,5" @onfocus="@(() => SetFieldHelp("split.pattern"))" @onmouseenter="@(() => SetFieldHelp("split.pattern"))" />
                    </div>
                }
                else if (_splitCutMode == SPLIT_CUT_RANGES)
                {
                    <div class="form-row">
                        <span class="form-label">Ranges*:</span>
                        <input class="form-input" @bind="_splitRanges" placeholder="0-00:24:00.000,00:24:00.000-END" @onfocus="@(() => SetFieldHelp("split.ranges"))" @onmouseenter="@(() => SetFieldHelp("split.ranges"))" />
                    </div>
                }
                else if (_splitCutMode == SPLIT_CUT_SPLIT_AT)
                {
                    <div class="form-row">
                        <span class="form-label">Split at*:</span>
                        <input class="form-input" @bind="_splitAt" placeholder="00:24:00.000" @onfocus="@(() => SetFieldHelp("split.splitAt"))" @onmouseenter="@(() => SetFieldHelp("split.splitAt"))" />
                    </div>
                }
                else if (_splitCutMode == SPLIT_CUT_TRIM)
                {
                    <div class="form-row">
                        <span class="form-label">Trim start:</span>
                        <input class="form-input" @bind="_splitTrimStart" @onfocus="@(() => SetFieldHelp("split.trimStart"))" @onmouseenter="@(() => SetFieldHelp("split.trimStart"))" />
                    </div>
                    <div class="form-row">
                        <span class="form-label">Trim end:</span>
                        <input class="form-input" @bind="_splitTrimEnd" @onfocus="@(() => SetFieldHelp("split.trimEnd"))" @onmouseenter="@(() => SetFieldHelp("split.trimEnd"))" />
                    </div>
                }
                else if (_splitCutMode == SPLIT_CUT_CHAPTERS_EACH)
                {
                }

                <div class="form-row">
                    <span class="form-label">Snap:</span>
                    <select class="form-input" style="width: 14ch;" @bind="_splitSnap" @onfocus="@(() => SetFieldHelp("split.snap"))" @onmouseenter="@(() => SetFieldHelp("split.snap"))">
                        <option value="@RemuxForge.Core.Models.MkvSplitSnapMode.Off">off</option>
                        <option value="@RemuxForge.Core.Models.MkvSplitSnapMode.Before">before</option>
                        <option value="@RemuxForge.Core.Models.MkvSplitSnapMode.After">after</option>
                        <option value="@RemuxForge.Core.Models.MkvSplitSnapMode.Nearest">nearest</option>
                    </select>
                </div>

                @* Naming *@
                <div class="form-section">== Naming ==</div>
                <div class="form-row">
                    <span class="form-label">Template:</span>
                    <input class="form-input" @bind="_splitOutputTemplate" placeholder="{source_name}.part{n:02d}.mkv" @onfocus="@(() => SetFieldHelp("split.template"))" @onmouseenter="@(() => SetFieldHelp("split.template"))" />
                </div>

                @* Opzioni *@
                <div class="form-section">== Opzioni ==</div>
                <div class="form-row">
                    <span class="form-label">Estensioni:</span>
                    <input class="form-input" @bind="_extensions" @onfocus="@(() => SetFieldHelp("split.extensions"))" @onmouseenter="@(() => SetFieldHelp("split.extensions"))" />
                </div>
            }
            else
            {
            @* Cartelle *@
            <div class="form-section">== Cartelle ==</div>
            <div class="form-row">
                <span class="form-label">Source*:</span>
                <input class="form-input" @bind="_sourceFolder" @onfocus="@(() => SetFieldHelp("remux.source"))" @onmouseenter="@(() => SetFieldHelp("remux.source"))" />
                <span class="btn-browse" @onclick="() => BrowseFolder(0)">[ .. ]</span>
            </div>
            <div class="form-row">
                <span class="form-label">Lingua:</span>
                <input class="form-input" @bind="_languageFolder" @onfocus="@(() => SetFieldHelp("remux.language"))" @onmouseenter="@(() => SetFieldHelp("remux.language"))" />
                <span class="btn-browse" @onclick="() => BrowseFolder(1)">[ .. ]</span>
            </div>
            <div class="form-row">
                <span class="form-label">Destinazione@(_overwrite ? "" : "*"):</span>
                <input class="form-input" @bind="_destFolder" @onfocus="@(() => SetFieldHelp("remux.destination"))" @onmouseenter="@(() => SetFieldHelp("remux.destination"))" />
                <span class="btn-browse" @onclick="() => BrowseFolder(2)">[ .. ]</span>
            </div>
            <div class="form-row">
                <span class="ui-toggle" @onclick="() => _overwrite = !_overwrite" @onmouseenter="@(() => SetFieldHelp("remux.overwrite"))">@(_overwrite ? "[X]" : "[ ]") Sovrascrivi sorgente</span>
            </div>
            <div class="form-row">
                <span class="ui-toggle" @onclick="() => _recursive = !_recursive" @onmouseenter="@(() => SetFieldHelp("remux.recursive"))">@(_recursive ? "[X]" : "[ ]") Ricorsivo</span>
            </div>

            @* Lingua e Tracce *@
            <div class="form-section">== Lingua e Tracce ==</div>
            <div class="form-row">
                <span class="form-label">Lingua target:</span>
                <input class="form-input" @bind="_targetLang" @onfocus="@(() => SetFieldHelp("remux.target"))" @onmouseenter="@(() => SetFieldHelp("remux.target"))" />
            </div>
            <div class="form-row">
                <span class="form-label">Codec audio:</span>
                <input class="form-input" @bind="_audioCodec" @onfocus="@(() => SetFieldHelp("remux.audioCodec"))" @onmouseenter="@(() => SetFieldHelp("remux.audioCodec"))" />
            </div>
            <div class="form-row">
                <span class="form-label">Mantieni audio:</span>
                <input class="form-input" @bind="_keepSrcAudio" @onfocus="@(() => SetFieldHelp("remux.keepAudio"))" @onmouseenter="@(() => SetFieldHelp("remux.keepAudio"))" />
            </div>
            <div class="form-row">
                <span class="form-label">Mantieni codec:</span>
                <input class="form-input" @bind="_keepSrcCodec" @onfocus="@(() => SetFieldHelp("remux.keepCodec"))" @onmouseenter="@(() => SetFieldHelp("remux.keepCodec"))" />
            </div>
            <div class="form-row">
                <span class="form-label">Mantieni sub:</span>
                <input class="form-input" @bind="_keepSrcSub" @onfocus="@(() => SetFieldHelp("remux.keepSub"))" @onmouseenter="@(() => SetFieldHelp("remux.keepSub"))" />
            </div>
            <div class="form-row">
                <span class="ui-toggle" @onclick="() => _subOnly = !_subOnly" @onmouseenter="@(() => SetFieldHelp("remux.subOnly"))">@(_subOnly ? "[X]" : "[ ]") Solo sottotitoli</span>
                <span class="ui-toggle" style="margin-left: 2ch;" @onclick="() => _audioOnly = !_audioOnly" @onmouseenter="@(() => SetFieldHelp("remux.audioOnly"))">@(_audioOnly ? "[X]" : "[ ]") Solo audio</span>
            </div>

            @* Sincronizzazione *@
            <div class="form-section">== Sincronizzazione ==</div>
            <div class="form-row">
                <span class="form-label">Speed:</span>
                <select class="form-input" style="width: 14ch;" @bind="_speedCorrectionMode" @onfocus="@(() => SetFieldHelp("remux.speed"))" @onmouseenter="@(() => SetFieldHelp("remux.speed"))">
                    <option value="@Options.SPEED_CORRECTION_OFF">Off</option>
                    <option value="@Options.SPEED_CORRECTION_AUTO">Auto</option>
                    <option value="@Options.SPEED_CORRECTION_MANUAL">Manual</option>
                </select>
                <span style="margin-left: 1ch;">Stretch</span>
                <input class="form-input" style="width: 14ch;" @bind="_manualStretchFactor" @onfocus="@(() => SetFieldHelp("remux.stretch"))" @onmouseenter="@(() => SetFieldHelp("remux.stretch"))" />
            </div>
            <div class="form-row">
                <span class="ui-toggle" @onclick="ToggleFrameSync" @onmouseenter="@(() => SetFieldHelp("remux.framesync"))">@(_frameSync ? "[X]" : "[ ]") Frame-sync (confronto visivo)</span>
            </div>
            <div class="form-row">
                <span class="ui-toggle" @onclick="ToggleDeepAnalysis" @onmouseenter="@(() => SetFieldHelp("remux.deep"))">@(_deepAnalysis ? "[X]" : "[ ]") Deep analysis (analisi completa)</span>
            </div>
            <div class="form-row">
                <span class="form-label">Delay audio:</span>
                <input class="form-input" style="width: 8ch;" @bind="_audioDelay" @onfocus="@(() => SetFieldHelp("remux.audioDelay"))" @onmouseenter="@(() => SetFieldHelp("remux.audioDelay"))" /> <span style="margin-left: 0.5ch;">ms</span>
            </div>
            <div class="form-row">
                <span class="form-label">Delay sub:</span>
                <input class="form-input" style="width: 8ch;" @bind="_subDelay" @onfocus="@(() => SetFieldHelp("remux.subDelay"))" @onmouseenter="@(() => SetFieldHelp("remux.subDelay"))" /> <span style="margin-left: 0.5ch;">ms</span>
            </div>

            @* Matching *@
            <div class="form-section">== Matching ==</div>
            <div class="form-row">
                <span class="form-label">Pattern match:</span>
                <input class="form-input" @bind="_matchPattern" @onfocus="@(() => SetFieldHelp("remux.match"))" @onmouseenter="@(() => SetFieldHelp("remux.match"))" />
            </div>
            <div class="form-row">
                <span class="form-label">Estensioni:</span>
                <input class="form-input" @bind="_extensions" @onfocus="@(() => SetFieldHelp("remux.extensions"))" @onmouseenter="@(() => SetFieldHelp("remux.extensions"))" />
            </div>

            @* Post-Processing audio *@
            <div class="form-section">== Post-processing audio ==</div>
            <div class="form-row">
                <span class="form-label">Formato audio@(_audioSourceFillEnabled ? "*" : ""):</span>
                <select class="form-input" style="width: 12ch;" value="@_audioFormat" @onchange="OnAudioFormatChanged" @onfocus="@(() => SetFieldHelp("remux.audioFormat"))" @onmouseenter="@(() => SetFieldHelp("remux.audioFormat"))">
                    <option value="">No</option>
                    <option value="flac">FLAC</option>
                    <option value="lpcm">LPCM</option>
                    <option value="aac">AAC</option>
                    <option value="opus">Opus</option>
                </select>
            </div>
            @if (_audioFormat.Length > 0)
            {
            <div class="form-row">
                <span class="form-label">Audio@(_audioSourceFillEnabled ? "*" : ""):</span>
                <select class="form-input" style="width: 14ch;" @bind="_audioProcessingScope" @onfocus="@(() => SetFieldHelp("remux.audioScope"))" @onmouseenter="@(() => SetFieldHelp("remux.audioScope"))">
                    <option value="disabled">Disabilitata</option>
                    <option value="lang">Lang</option>
                    <option value="all">Tutti</option>
                </select>
            </div>
            }
            @if (_audioFormat.Length > 0)
            {
                <div class="form-row">
                    <span class="ui-toggle" @onclick="ToggleAudioSourceFill" @onmouseenter="@(() => SetFieldHelp("remux.audioSourceFill"))">@(_audioSourceFillEnabled ? "[X]" : "[ ]") Audio source fill</span>
                </div>
            }
            @if (_audioFormat.Length > 0 && _audioSourceFillEnabled)
            {
            <div class="form-row">
                <span class="form-label">Soglia*:</span>
                <input class="form-input" style="width: 8ch;" @bind="_audioSourceFillThresholdMs" @onfocus="@(() => SetFieldHelp("remux.audioSourceFillThreshold"))" @onmouseenter="@(() => SetFieldHelp("remux.audioSourceFillThreshold"))" /> <span style="margin-left: 0.5ch;">ms</span>
            </div>
            <div class="form-row">
                <span class="form-label">Lingua source*:</span>
                <input class="form-input" style="width: 10ch;" @bind="_audioSourceFillLanguage" @onfocus="@(() => SetFieldHelp("remux.audioSourceFillLang"))" @onmouseenter="@(() => SetFieldHelp("remux.audioSourceFillLang"))" />
            </div>
            <div class="form-row">
                <span class="form-label">Modalita*:</span>
                <span class="ui-toggle" @onclick="() => _audioSourceFillStart = !_audioSourceFillStart" @onmouseenter="@(() => SetFieldHelp("remux.audioSourceFillStart"))">@(_audioSourceFillStart ? "[X]" : "[ ]") Inizio</span>
                <span class="ui-toggle" style="margin-left: 2ch;" @onclick="() => _audioSourceFillEnd = !_audioSourceFillEnd" @onmouseenter="@(() => SetFieldHelp("remux.audioSourceFillEnd"))">@(_audioSourceFillEnd ? "[X]" : "[ ]") Fine</span>
                @if (_deepAnalysis)
                {
                    <span class="ui-toggle" style="margin-left: 2ch;" @onclick="() => _audioSourceFillInsertSilence = !_audioSourceFillInsertSilence" @onmouseenter="@(() => SetFieldHelp("remux.audioSourceFillInsert"))">@(_audioSourceFillInsertSilence ? "[X]" : "[ ]") Insert silence</span>
                }
            </div>
            }
            @if ((_audioFormat == "flac" || _audioFormat == "lpcm") && _audioProcessingScope != "disabled")
            {
            <div class="form-row">
                <span class="ui-toggle" @onclick="() => _audioDownsample24To16 = !_audioDownsample24To16" @onmouseenter="@(() => SetFieldHelp("remux.audio24"))">@(_audioDownsample24To16 ? "[X]" : "[ ]") 24bit -> 16bit</span>
            </div>
            }
            @if (_audioFormat.Length > 0 && _audioProcessingScope != "disabled")
            {
            <div class="form-row">
                <span class="ui-toggle" @onclick="() => _audioPeakNormalize = !_audioPeakNormalize" @onmouseenter="@(() => SetFieldHelp("remux.audioNormalize"))">@(_audioPeakNormalize ? "[X]" : "[ ]") Normalizzazione</span>
                @if (_audioPeakNormalize)
                {
                    <input class="form-input" style="width: 8ch;" @bind="_audioPeakTargetDb" @onfocus="@(() => SetFieldHelp("remux.audioNormalize"))" @onmouseenter="@(() => SetFieldHelp("remux.audioNormalize"))" />
                    <span>dB</span>
                }
            </div>
            }
            <div class="form-row">
                <span class="form-label">Rinomina audio:</span>
                <select class="form-input" style="width: 14ch;" @bind="_audioRenameScope" @onfocus="@(() => SetFieldHelp("remux.rename"))" @onmouseenter="@(() => SetFieldHelp("remux.rename"))">
                    <option value="disabled">No</option>
                    <option value="lang">Lang</option>
                    <option value="all">Tutti</option>
                </select>
            </div>

            @* Post-Processing video *@
            <div class="form-section">== Post-processing video ==</div>
            <div class="form-row">
                <span class="form-label">Encoding video:</span>
                <select class="form-input" style="width: 30ch;" @bind="_encodingProfile" @onfocus="@(() => SetFieldHelp("remux.encoding"))" @onmouseenter="@(() => SetFieldHelp("remux.encoding"))">
                    <option value="">(nessuno)</option>
                    @for (int i = 0; i < AppSettingsService.Instance.Settings.EncodingProfiles.Count; i++)
                    {
                        <option value="@AppSettingsService.Instance.Settings.EncodingProfiles[i].Name">@AppSettingsService.Instance.Settings.EncodingProfiles[i].Name</option>
                    }
                </select>
            </div>
            }
            </div>
            <div class="config-help-pane">
                <div class="config-help-title">@_fieldHelpTitle</div>
                <div class="config-help-text">@_fieldHelpText</div>
            </div>
        </div>
        @if (_validationError.Length > 0)
        {
            <div style="padding: 0.5em 1em; color: var(--color-error); white-space: pre-line;">@_validationError</div>
        }
        <div class="dialog-footer">
            <button @onclick="Apply">OK</button>
            <button @onclick="OnClose">Annulla</button>
        </div>
    </div>
</div>

@* Dialog browse cartella *@
@if (_showBrowse)
{
    <FolderBrowserDialog InitialPath="@_browseInitialPath"
                          ShowFiles="@_browseShowFiles"
                          AllowCurrentFolderSelection="@_browseAllowCurrentFolderSelection"
                          OnClose="CloseBrowse"
                          OnSelect="ApplyBrowse" />
}

@code {
    #region Costanti

    /// <summary>
    /// Split per pattern capitoli
    /// </summary>
    private const string SPLIT_CUT_PATTERN = "pattern";

    /// <summary>
    /// Split per range espliciti
    /// </summary>
    private const string SPLIT_CUT_RANGES = "ranges";

    /// <summary>
    /// Split per punti di taglio
    /// </summary>
    private const string SPLIT_CUT_SPLIT_AT = "split-at";

    /// <summary>
    /// Trim singolo segmento
    /// </summary>
    private const string SPLIT_CUT_TRIM = "trim";

    /// <summary>
    /// Split capitolo per capitolo
    /// </summary>
    private const string SPLIT_CUT_CHAPTERS_EACH = "chapters-each";

    #endregion

    /// <summary>
    /// Opzioni correnti da precompilare
    /// </summary>
    [Parameter] public Options Options { get; set; }

    /// <summary>
    /// Evento chiusura dialog
    /// </summary>
    [Parameter] public EventCallback OnClose { get; set; }

    /// <summary>
    /// Evento applicazione opzioni
    /// </summary>
    [Parameter] public EventCallback<Options> OnApply { get; set; }

    /// <summary>
    /// Flag: mostra dialog browse cartella
    /// </summary>
    private bool _showBrowse;

    /// <summary>
    /// Percorso iniziale per il dialog browse
    /// </summary>
    private string _browseInitialPath = "";

    /// <summary>
    /// Flag: il dialog browse deve mostrare file selezionabili
    /// </summary>
    private bool _browseShowFiles;

    /// <summary>
    /// Flag: il dialog browse puo' confermare la cartella corrente
    /// </summary>
    private bool _browseAllowCurrentFolderSelection = true;

    /// <summary>
    /// Indice campo destinazione del browse: 0=source, 1=lingua, 2=dest
    /// </summary>
    private int _browseFieldIndex = -1;

    /// <summary>
    /// Flag: configurazione modalita' split
    /// </summary>
    private bool _isSplitMode;

    /// <summary>
    /// Cartella sorgente
    /// </summary>
    private string _sourceFolder = "";

    /// <summary>
    /// Cartella lingua
    /// </summary>
    private string _languageFolder = "";

    /// <summary>
    /// Cartella destinazione
    /// </summary>
    private string _destFolder = "";

    /// <summary>
    /// Flag sovrascrivi sorgente
    /// </summary>
    private bool _overwrite;

    /// <summary>
    /// Flag ricorsivo
    /// </summary>
    private bool _recursive = true;

    /// <summary>
    /// Lingua target (CSV)
    /// </summary>
    private string _targetLang = "";

    /// <summary>
    /// Codec audio (CSV)
    /// </summary>
    private string _audioCodec = "";

    /// <summary>
    /// Lingue audio sorgente da mantenere (CSV)
    /// </summary>
    private string _keepSrcAudio = "";

    /// <summary>
    /// Codec audio sorgente da mantenere (CSV)
    /// </summary>
    private string _keepSrcCodec = "";

    /// <summary>
    /// Sottotitoli sorgente da mantenere (CSV)
    /// </summary>
    private string _keepSrcSub = "";

    /// <summary>
    /// Flag solo sottotitoli
    /// </summary>
    private bool _subOnly;

    /// <summary>
    /// Flag solo audio
    /// </summary>
    private bool _audioOnly;

    /// <summary>
    /// Modalita' speed correction
    /// </summary>
    private string _speedCorrectionMode = Options.SPEED_CORRECTION_OFF;

    /// <summary>
    /// Stretch factor manuale
    /// </summary>
    private string _manualStretchFactor = "";

    /// <summary>
    /// Flag frame-sync
    /// </summary>
    private bool _frameSync;

    /// <summary>
    /// Flag deep analysis
    /// </summary>
    private bool _deepAnalysis;

    /// <summary>
    /// Delay audio in ms (stringa per binding input)
    /// </summary>
    private string _audioDelay = "0";

    /// <summary>
    /// Delay sottotitoli in ms (stringa per binding input)
    /// </summary>
    private string _subDelay = "0";

    /// <summary>
    /// Abilita UI audio source fill
    /// </summary>
    private bool _audioSourceFillEnabled;

    /// <summary>
    /// Soglia audio source fill in ms (stringa per binding input)
    /// </summary>
    private string _audioSourceFillThresholdMs = "0";

    /// <summary>
    /// Lingua source per audio source fill
    /// </summary>
    private string _audioSourceFillLanguage = "";

    /// <summary>
    /// Audio source fill: inizio file
    /// </summary>
    private bool _audioSourceFillStart;

    /// <summary>
    /// Audio source fill: fine file
    /// </summary>
    private bool _audioSourceFillEnd;

    /// <summary>
    /// Audio source fill: INSERT_SILENCE DeepAnalysis
    /// </summary>
    private bool _audioSourceFillInsertSilence;

    /// <summary>
    /// Pattern matching episodi
    /// </summary>
    private string _matchPattern = @"S(\d+)E(\d+)";

    /// <summary>
    /// Estensioni file (CSV)
    /// </summary>
    private string _extensions = "mkv";

    /// <summary>
    /// Formato audio post-processing
    /// </summary>
    private string _audioFormat = "";

    /// <summary>
    /// Tracce da processare nel formato audio scelto
    /// </summary>
    private string _audioProcessingScope = "disabled";

    /// <summary>
    /// Flag 24bit -> 16bit
    /// </summary>
    private bool _audioDownsample24To16;

    /// <summary>
    /// Flag peak normalization
    /// </summary>
    private bool _audioPeakNormalize;

    /// <summary>
    /// Target peak normalization
    /// </summary>
    private string _audioPeakTargetDb = "-1.0";

    /// <summary>
    /// Scope rinomina audio
    /// </summary>
    private string _audioRenameScope = "disabled";

    /// <summary>
    /// Nome profilo encoding selezionato, vuoto = nessuno
    /// </summary>
    private string _encodingProfile = "";

    /// <summary>
    /// Sorgente split: file MKV o cartella
    /// </summary>
    private string _splitSource = "";

    /// <summary>
    /// Source raw split
    /// </summary>
    private string _splitSourceRaw = "";

    /// <summary>
    /// Cartella output split
    /// </summary>
    private string _splitOutputDir = "";

    /// <summary>
    /// Pattern capitoli split
    /// </summary>
    private string _splitPattern = "";

    /// <summary>
    /// Modalita' di taglio split selezionata
    /// </summary>
    private string _splitCutMode = "";

    /// <summary>
    /// Ranges split
    /// </summary>
